---
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/images/logo-small.png" />
    <meta name="generator" content={Astro.generator} />
    <title>Comando 99</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&family=Roboto+Flex:opsz,wght,XOPQ,XTRA,YOPQ,YTDE,YTFI,YTLC,YTUC@8..144,100..1000,96,468,79,-203,738,514,712&family=Stick+No+Bills:wght@200..800&display=swap"
      rel="stylesheet"
    />
  </head>
  <div class="scanline-overlay"></div>
  <body>
    <slot />
    <Footer />
  </body>

  <style>
    html,
    body {
      margin: 0;
      width: 100%;
      height: 100%;
      font-family:
        "Rajdhani",
        system-ui,
        -apple-system,
        BlinkMacSystemFont,
        "Segoe UI",
        Roboto,
        Oxygen,
        Ubuntu,
        Cantarell,
        "Open Sans",
        "Helvetica Neue",
        sans-serif;
      color: white;
      background: black;
      max-width: 100vw;
      overflow-x: hidden;
      scroll-behavior: smooth;
      scroll-padding-top: 70px;
    }

    :global(html) {
      scrollbar-width: thin;
      scrollbar-color: #a00a05 #050505;
    }

    :global(::-webkit-scrollbar) {
      width: 0.85rem;
      height: 0.85rem;
      background: #050505;
    }

    :global(::-webkit-scrollbar-track) {
      background: #050505;
    }

    :global(::-webkit-scrollbar-thumb) {
      background: linear-gradient(180deg, #a00a05 0%, #dd2216 100%);
      border: 2px solid #050505;
      border-radius: 25px;
    }

    :global(::-webkit-scrollbar-thumb:hover) {
      background: linear-gradient(180deg, #a00a05 0%, #f43627 100%);
    }

    @media (prefers-reduced-motion: reduce) {
      :global(html) {
        scroll-behavior: auto;
      }
    }

    .scanline-overlay {
      position: fixed;
      background:
        linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%),
        linear-gradient(
          90deg,
          rgba(255, 0, 0, 0.02),
          rgba(0, 255, 0, 0.01),
          rgba(0, 0, 255, 0.02)
        );
      background-size:
        100% 2px,
        3px 100%;
      pointer-events: none;
      z-index: 2;

      width: 100%;
      height: 100%;
    }
  </style>


</html>
