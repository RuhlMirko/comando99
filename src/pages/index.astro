---
import Welcome from "../components/Welcome.astro";
import Layout from "../layouts/Layout.astro";
import Galeria from "../components/Galeria.astro";
import Faq from "../components/Faq.astro";
import Navbar from "../components/Navbar.astro";
import Showcase from "../components/Showcase.astro";
---

<Layout>
  <Navbar
    navLinks={{
      hero: "Inicio",
      showcase: "Sobre Nosotros",
      gallery: "Galeria",
      faq: "Preguntas frecuentes",
    }}
  />
  <Welcome />
  <div class="reveal-up reveal-delay-1">
    <Showcase />
  </div>
  <div class="reveal-up reveal-delay-2">
    <Galeria />
  </div>
  <div class="reveal-up reveal-delay-3">
    <Faq />
  </div>
</Layout>

<style is:global>
  :root {
    --bg-secondary: #a6292e;
    --text-primary: #c7191e;
  }
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  body {
    max-width: 100vw;
    overflow-x: hidden;
    background: #121212;
    color: white;
    font-family:
      "Rajdhani",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }

  h2 {
    font-size: 50px;
    padding-bottom: 0;
  }

  section {
    margin-inline: 5vw;
    padding-bottom: 1em;
    margin-bottom: 2em;
    /* border-bottom: 2px solid rgba(165, 42, 42, 0.445); */
  }

  .navigation-chevron {
    margin-left: 4px;
    font-size: 0.8em;
  }

  .reveal-up {
    opacity: 0;
    transform: translateY(36px);
  }

  .reveal-up.is-revealed {
    animation: reveal-from-bottom 650ms ease-out both;
  }

  .reveal-delay-1 {
    animation-delay: 80ms;
  }

  .reveal-delay-2 {
    animation-delay: 180ms;
  }

  .reveal-delay-3 {
    animation-delay: 280ms;
  }

  @keyframes reveal-from-bottom {
    from {
      opacity: 0;
      transform: translateY(36px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-up {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  const revealItems = document.querySelectorAll(".reveal-up");
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (prefersReducedMotion) {
    revealItems.forEach((item) => item.classList.add("is-revealed"));
  } else if ("IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (entries, currentObserver) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          entry.target.classList.add("is-revealed");
          currentObserver.unobserve(entry.target);
        });
      },
      {
        threshold: 0.15,
        rootMargin: "0px 0px -8% 0px",
      },
    );

    revealItems.forEach((item) => observer.observe(item));
  } else {
    revealItems.forEach((item) => item.classList.add("is-revealed"));
  }
</script>
