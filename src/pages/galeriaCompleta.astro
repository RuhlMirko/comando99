---
import Navbar from "../components/Navbar.astro";
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

const galleryFiles = import.meta.glob("/public/images/galeria/*/*.*", {
  eager: true,
});

const getPublicImagePaths = (dir: string) => {
  return Object.keys(galleryFiles)
    .filter((path) => path.includes(`/public/images/galeria/${dir}/`))
    .sort((a, b) => a.localeCompare(b))
    .map((path) => path.replace("/public", ""));
};

const categories = {
  misiones: "Misiones",
  entrenamientos: "Entrenamientos",
  patrullas: "Patrullas",
  escenas: "Escenas",
} as const;

const images = Object.fromEntries(
  Object.keys(categories).map((key) => [key, getPublicImagePaths(key)]),
) as Record<keyof typeof categories, string[]>;
---

<Layout>
  <Navbar
    navLinks={{
      misiones: "Misiones",
      training: "Entrenamientos",
      escenas: "Escenas",
      patrullas: "Patrullas",
    }}
    isNotFrontPage
  />
  <main>
    <header>
      <h1>Galeria de Comando 99</h1>
      <p>
        Esta es una recopilacion de fotos/capturas de pantallas de misiones,
        entrenamientos, escenas recreadas y patrullas realizadas en nuestras
        actividades.
      </p>
    </header>

    <div>
      <h2>Misiones</h2>
      <div class="gallery-list" id="misiones">
        {
          images.misiones.map((item, index) => {
            const filename =
              item.split("/").pop()?.split(".")[0].replaceAll("-", "/") ||
              "imagen";
            return (
              <div class="gallery-item">
                <Image
                  src={item}
                  alt={`Comando 99 - ${filename}`}
                  width={800}
                  height={200}
                  loading={index < 6 ? "eager" : "lazy"}
                  fetchpriority={index === 0 ? "high" : "auto"}
                  decoding="async"
                />
                <p>{filename}</p>
              </div>
            );
          })
        }
      </div>
      <h2>Entrenamientos</h2>
      <div class="gallery-list" id="training">
        {
          images.entrenamientos.map((item, index) => {
            const filename =
              item.split("/").pop()?.split(".")[0].replaceAll("-", "/") ||
              "imagen";
            return (
              <div class="gallery-item">
                <Image
                  src={item}
                  alt={`Comando 99 - ${filename}`}
                  width={800}
                  height={200}
                  loading={index < 3 ? "eager" : "lazy"}
                  decoding="async"
                  fetchpriority="low"
                />
                <p>{filename}</p>
              </div>
            );
          })
        }
      </div>
      <h2>Patrullas</h2>
      <div class="gallery-list" id="patrullas">
        {
          images.patrullas.map((item, index) => {
            const filename =
              item.split("/").pop()?.split(".")[0].replaceAll("-", "/") ||
              "imagen";
            return (
              <div class="gallery-item">
                <Image
                  src={item}
                  alt={`Comando 99 - ${filename}`}
                  width={800}
                  height={200}
                  loading={index < 2 ? "eager" : "lazy"}
                  decoding="async"
                  fetchpriority="low"
                />
                <p>{filename}</p>
              </div>
            );
          })
        }
      </div>
      <h2>Escenas</h2>
      <div class="gallery-list" id="escenas">
        {
          images.escenas.map((item, index) => {
            const filename =
              item.split("/").pop()?.split(".")[0].split("-").join(" ") ||
              "imagen";
            return (
              <div class="gallery-item">
                <Image
                  src={item}
                  alt={`Comando 99 - ${filename}`}
                  width={800}
                  height={200}
                  loading={index < 2 ? "eager" : "lazy"}
                  decoding="async"
                  fetchpriority="low"
                />
                <p>{filename}</p>
              </div>
            );
          })
        }
      </div>
      <div class="gallery-modal" aria-hidden="true">
        <button class="gallery-modal-close" aria-label="Cerrar">&times;</button>
        <img class="gallery-modal-image" alt="" />
      </div>
    </div>
  </main>
</Layout>

<style>
  :global(body) {
    background:
      radial-gradient(
        circle at 12% 10%,
        rgba(166, 20, 20, 0.3),
        transparent 30%
      ),
      radial-gradient(
        circle at 88% 14%,
        rgba(255, 97, 34, 0.2),
        transparent 28%
      ),
      linear-gradient(160deg, #050505 0%, #0e0909 45%, #030202 100%);
  }

  main {
    position: relative;
    padding-inline: clamp(0.75rem, 1vw + 0.5rem, 1.5rem);
    padding-bottom: 4rem;
  }

  main::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
    opacity: 0.25;
    z-index: 0;
  }

  main > * {
    position: relative;
  }

  h1,
  h2,
  p {
    display: block;
  }

  main header {
    margin-top: 138px;
    margin-bottom: 56px;
    padding: clamp(1rem, 1.5vw, 1.4rem);
    border: 1px solid rgba(255, 140, 61, 0.3);
    background: linear-gradient(
      120deg,
      rgba(34, 15, 15, 0.88),
      rgba(10, 10, 10, 0.9)
    );
    backdrop-filter: blur(10px);
    box-shadow: 0 16px 38px rgba(0, 0, 0, 0.45);
  }

  h1,
  h2 {
    font-family: "Stick No Bills";
    letter-spacing: 1px;
  }

  h1 {
    font-size: clamp(2.6rem, 4vw, 4.3rem);
    margin: 0;
    text-transform: uppercase;
    text-align: center;
    color: #ffe9d1;
    text-shadow: 0 3px 18px rgba(255, 86, 20, 0.18);
  }

  h2 {
    font-size: clamp(2rem, 2.4vw, 2.85rem);
    margin: 0;
    border-top: 1px solid rgba(255, 157, 87, 0.4);
    border-bottom: 1px solid rgba(255, 157, 87, 0.15);
    background: linear-gradient(
      to right,
      rgba(48, 14, 14, 0.94),
      rgba(17, 8, 8, 0.94)
    );
    color: #ffd4aa;
    padding: 0.55rem 0;
    text-transform: uppercase;
    text-align: center;
    top: 67px;
    z-index: 20;
    backdrop-filter: blur(18px);
    box-shadow: inset 0 0 16px rgba(0, 0, 0, 0.35);
  }

  p {
    font-size: clamp(1.3rem, 1.4vw + 0.9rem, 1.8rem);
    max-width: 68ch;
    margin: 0.8rem auto 0;
    line-height: 1.28;
    text-align: center;
    color: #f7ddd0;
  }

  .gallery-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
    margin-bottom: 22px;
    padding: 1rem;
    background: linear-gradient(
      160deg,
      rgba(14, 14, 14, 0.88),
      rgba(8, 8, 8, 0.88)
    );
    border: 1px solid rgba(255, 148, 60, 0.2);
    box-shadow: 0 18px 28px rgba(0, 0, 0, 0.34);
  }

  @media (min-width: 820px) {
    .gallery-list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255, 175, 110, 0.18);
    background: #090909;
    transform: translateY(0);
    transition:
      transform 0.28s ease,
      border-color 0.28s ease,
      box-shadow 0.28s ease;
  }

  .gallery-item::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 85% 12%,
      rgba(255, 157, 87, 0.2),
      transparent 42%
    );
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
    z-index: 2;
  }

  .gallery-item::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(9, 8, 8, 0.92) 5%,
      rgba(9, 8, 8, 0.15) 48%,
      transparent 74%
    );
    opacity: 0.85;
    transition: opacity 0.2s;
    pointer-events: none;
    z-index: 1;
  }

  .gallery-item img {
    width: 100%;
    height: auto;
    object-fit: cover;
    aspect-ratio: 16/9;
    display: block;
    filter: saturate(92%);
    transform: scale(1);
    transition:
      transform 0.45s ease,
      filter 0.35s ease;
  }

  .gallery-item p {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    margin: 0;
    padding: 0.58rem 0.75rem;
    font-size: 1.04rem;
    letter-spacing: 0.3px;
    text-align: left;
    text-transform: uppercase;
    color: #ffe2c1;
    background: linear-gradient(to right, rgba(14, 14, 14, 0.9), transparent);
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.22s ease,
      transform 0.22s ease;
    pointer-events: none;
  }

  .gallery-item:hover {
    transform: translateY(-6px);
    border-color: rgba(255, 167, 111, 0.5);
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.5);
  }

  .gallery-item:hover::before {
    opacity: 1;
  }

  .gallery-item:hover::after {
    opacity: 1;
  }

  .gallery-item:hover img {
    transform: scale(1.05);
    filter: saturate(108%);
    cursor: pointer;
  }

  .gallery-item:hover p {
    opacity: 1;
    transform: translateY(0);
  }

  .gallery-list:hover .gallery-item:not(:hover) {
    opacity: 0.84;
  }

  .gallery-modal {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(
        circle at center,
        rgba(43, 17, 17, 0.35),
        rgba(0, 0, 0, 0.92)
      ),
      rgba(0, 0, 0, 0.82);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.2s,
      visibility 0.2s;
    z-index: 1000;
  }

  .gallery-modal.is-open {
    opacity: 1;
    visibility: visible;
  }

  .gallery-modal-image {
    max-width: 92vw;
    max-height: 92vh;
    object-fit: contain;
    border: 1px solid rgba(255, 166, 98, 0.42);
    background: #0a0909;
    box-shadow: 0 18px 46px rgba(0, 0, 0, 0.62);
  }

  .gallery-modal-close {
    position: absolute;
    top: 6vh;
    right: 30px;
    font-size: 50px;
    line-height: 1;
    width: 68px;
    aspect-ratio: 1;
    border: 1px solid rgba(255, 187, 132, 0.5);
    border-radius: 999px;
    color: #fff2de;
    background: rgba(124, 21, 21, 0.8);
    cursor: pointer;
    transition:
      background 0.2s,
      transform 0.2s;
  }

  .gallery-modal-close:hover {
    background: rgb(177, 34, 34);
    transform: scale(1.06);
  }

  @media (max-width: 800px) {
    main {
      padding-inline: 0.55rem;
      padding-bottom: 2.4rem;
    }

    main header {
      margin-top: 122px;
      margin-bottom: 34px;
      padding: 0.9rem 0.75rem;
    }

    h2 {
      position: static;
      padding: 0.5rem 0;
      font-size: clamp(1.75rem, 8vw, 2.25rem);
    }

    .gallery-list {
      gap: 10px;
      padding: 0.6rem;
      margin-bottom: 18px;
    }

    .gallery-item p {
      opacity: 1;
      transform: translateY(0);
      font-size: 0.95rem;
      background: linear-gradient(to top, rgba(14, 14, 14, 0.9), transparent);
    }

    .gallery-modal-close {
      top: 20px;
      right: 14px;
      width: 54px;
      font-size: 38px;
    }
  }
</style>
<script>
  const photoLists = document.querySelectorAll(".gallery-list");
  const modal = document.querySelector(".gallery-modal");
  const modalImage = document.querySelector(
    ".gallery-modal-image",
  ) as HTMLImageElement;
  const modalClose = document.querySelector(
    ".gallery-modal-close",
  ) as HTMLButtonElement;

  const openModal = (src: string, alt: string) => {
    if (!modal || !modalImage) return;
    modalImage.src = src;
    modalImage.alt = alt || "";
    modal.classList.add("is-open");
    modal.setAttribute("aria-hidden", "false");
  };

  const closeModal = () => {
    if (!modal || !modalImage) return;
    modal.classList.remove("is-open");
    modal.setAttribute("aria-hidden", "true");
    modalImage.src = "";
  };

  photoLists.forEach((photoList) => {
    photoList.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLImageElement)) return;
      openModal(target.currentSrc || target.src, target.alt);
    });
  });

  modalClose?.addEventListener("click", closeModal);
  modal?.addEventListener("click", (event) => {
    if (event.target === modal) closeModal();
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeModal();
  });
</script>
