---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout>
  <Navbar
    navLinks={{
      actividades: "Horario",
      roles: "Roles",
      escalafon: "Escalafon",
    }}
    isNotFrontPage
  />

  <main>
    <section>
      <h2>Actividades durante la semana</h2>
      <div class="actividades-container" id="actividades">
        <h3>Lunes</h3>
        <h3>Martes</h3>
        <h3>Miercoles</h3>
        <h3>Jueves</h3>
        <h3>Viernes</h3>
        <h3>Sabado</h3>
        <h3>Domingo</h3>
        <h3>Entrenamientos de Armas Separadas</h3>
        <h3>Entrenamiento general + Patrulla</h3>
        <h3>Entrenamiento de Armas Conjunta</h3>
        <h3>Entrenamiento general + Patrulla</h3>
        <h3>Cursos</h3>
        <h3>Entrenamiento de Armas Separadas</h3>
        <h3>Misiones</h3>
      </div>
    </section>

    <section>
      <h2>Roles</h2>
      <p>
        Cada miembro podra pertenecer a un arma que desee, solo podra
        capacitarse y ejercer los roles de su arma correspondiente.
      </p>
      <div class="roles" id="roles">
        <div class="role-cell role-header desktop-only">Inicial</div>
        <div class="role-cell role-header">Capacitacion Rol Basico</div>
        <div class="role-cell role-header">Capacitacion Rol Experimentado</div>
        <div class="role-cell role-header">Capacitacion Rol Avanzado</div>
        <div class="role-cell role-header">Capacitacion Maestria</div>

        <div class="role-cell role-name fusilero desktop-only">Fusilero</div>
        <div class="role-cell role-section infanteria">Arma de infanteria</div>

        <div class="role-cell infanteria">Explorador</div>
        <div class="role-cell infanteria">Tirador selecto</div>
        <div class="role-cell infanteria">Francotirador</div>
        <div class="role-cell infanteria">Observador</div>

        <div class="role-cell infanteria">Granadero</div>
        <div class="role-cell infanteria">
          <span>Soldado AT Ligero</span>
          <br />
          <span>Soldado AA Ligero</span>
        </div>
        <div class="role-cell infanteria">Soldado AT Pesado</div>
        <div class="role-cell infanteria">Operador de Armas Pesadas</div>

        <div class="role-cell infanteria">Enfermero</div>
        <div class="role-cell infanteria">Enfermero de Combate</div>
        <div class="role-cell infanteria">Medico de combate</div>
        <div class="role-cell infanteria">Medico Cirujano</div>

        <div class="role-cell infanteria">
          <span>Portamuniciones</span>
          <br />
          <span>Fusilero Automatico</span>
        </div>
        <div class="role-cell infanteria">Ametrallador ligero</div>
        <div class="role-cell infanteria">Ametrallador mediano</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell infanteria">Ingeniero EOD</div>
        <div class="role-cell infanteria">Ingeniero Zapador</div>
        <div class="role-cell infanteria">Especialista en demoliciones</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell role-section caballeria">Arma de caballeria</div>

        <div class="role-cell caballeria">Conductor de Mecanizada</div>
        <div class="role-cell caballeria">Artillero de Mecanizada</div>
        <div class="role-cell caballeria">Comandante de Mecanizada</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell caballeria">Conductor de tanque</div>
        <div class="role-cell caballeria">Mecanico tanquista</div>
        <div class="role-cell caballeria">Artillero de tanque</div>
        <div class="role-cell caballeria">Comandante de Tanque</div>

        <div class="role-cell caballeria">Artillero de Movilidad Ligera</div>
        <div class="role-cell caballeria">Conductor de Movilidad Ligera</div>
        <div class="role-cell caballeria">Cabeza de Convoy</div>
        <div class="role-cell caballeria">
          Experto en Planeamiento y Maniobra
        </div>

        <div class="role-cell caballeria">Ingeniero Mecanico</div>
        <div class="role-cell caballeria">
          Especialista en recuperacion y remolque
        </div>
        <div class="role-cell role-empty"></div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell caballeria">Paramedico</div>
        <div class="role-cell caballeria">Conductor de ambulancia</div>
        <div class="role-cell caballeria">Especialista en rescate blindado</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell caballeria">Exploracion motorizada</div>
        <div class="role-cell caballeria">Exploracion ligera</div>
        <div class="role-cell caballeria">
          Especialista en exploracion motorizada
        </div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell role-section servicios">Arma de servicios</div>

        <div class="role-cell servicios">Radio Operador de escuadra</div>
        <div class="role-cell servicios">
          Encargado de control aereo (J.T.A.C.)
        </div>
        <div class="role-cell servicios">Observador de Artilleria</div>
        <div class="role-cell servicios">Especialista en comunicaciones</div>

        <div class="role-cell servicios">Operador de mortero</div>
        <div class="role-cell servicios">Operador de Artilleria</div>
        <div class="role-cell servicios">
          Operador de Artilleria Autopropulsada
        </div>
        <div class="role-cell servicios">
          Coordinador de fuego de artilleria
        </div>

        <div class="role-cell servicios">Operador de dron explorador</div>
        <div class="role-cell servicios">Operador de dron de combate</div>
        <div class="role-cell servicios">
          Operador de Dron UAV de exploracion
        </div>
        <div class="role-cell servicios">Operador de Dron UAV de Ataque</div>

        <div class="role-cell servicios">Paramedico</div>
        <div class="role-cell servicios">Especialista en rescate aereo</div>
        <div class="role-cell servicios">Cirujano de emergencias</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell servicios">Conductor de logistica pesado</div>
        <div class="role-cell servicios">Conductor de logistica liviano</div>
        <div class="role-cell servicios">
          Especialista de logistica de ala rotativa
        </div>
        <div class="role-cell servicios">
          Especialista de logistica de ala fija
        </div>

        <div class="role-cell role-level">Nivel Basico (0-50 pts)</div>
        <div class="role-cell role-level">Nivel Intermedio (51-100 pts)</div>
        <div class="role-cell role-level">Nivel Avanzado (101-150 pts)</div>
        <div class="role-cell role-level">Nivel Maestro (151+ pts)</div>

        <div class="role-cell servicios">
          Aviones de entrenamiento y reconocimiento
        </div>
        <div class="role-cell servicios">Su-25/A-29</div>
        <div class="role-cell servicios">A-10C/F-16</div>
        <div class="role-cell servicios">F-22/Mig-29</div>

        <div class="role-cell servicios">Helicopteros de transporte</div>
        <div class="role-cell servicios">AH-6 (Little bird) / UH-1Y</div>
        <div class="role-cell servicios">AH-64D/AH-1Z</div>
        <div class="role-cell servicios">UH-60 DAP / RAH-66</div>
      </div>
    </section>

    <section class="rol-info-container">
      <h2>Ascenso de Roles</h2>
      <p>
        Los roles tienen su propio sistema de ascenso, despues de completar sus
        correspondientes cantidad de actividades en su rol podra rendir su
        siguiente nivel.
      </p>
      <div class="rol-ascenso">
        <h3>Nivel Basico</h3>
        <h3>Nivel Experimentado ⇒ 10 actividades</h3>
        <h3>Nivel Avanzado ⇒ 25 actividades</h3>
        <h3>Maestria ⇒ 35 actividades</h3>
      </div>
    </section>

    <section>
      <h2>Escalafon</h2>
      <p>
        Todos los nuevos miembros entraran como rango de recluta, los cuales
        tendran 4 clases de capacitacion para ascender como Aspirante
      </p>
    </section>

    <section id="escalafon">
      <h2>Escalafon</h2>
    </section>
  </main>
</Layout>

<style>
  main {
    padding-top: 70px;
    width: 90%;
    margin: 0 auto;
  }

  h1,
  h2,
  p {
    display: block;
  }

  h2 {
    font-size: 3rem;
    margin-bottom: 0.5rem;
    font-family: "Stick No Bills", sans-serif;
    font-weight: 500;
    letter-spacing: 2px;
    border-bottom: 3px solid rgba(172, 69, 69, 0.459);
    padding-left: 1.5rem;
  }
  p {
    font-size: 1.5rem;
    max-width: 70ch;
    margin-top: 0;
  }

  main section {
    border-bottom: 1px solid rgba(128, 128, 128, 0.459);
  }

  .actividades-container {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    grid-column-gap: 0px;
    grid-row-gap: 0px;
    margin-top: 1rem;
    margin-bottom: 3rem;
  }

  .actividades-container h3 {
    padding: 8px;
    margin: 0;
    word-wrap: break-word;
    overflow-wrap: break-word;
    border: 1px solid brown;
    text-align: center;
    align-self: stretch;
    height: 100%;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .actividades-container h3:nth-child(-n + 7) {
    /* background-color: #bd1c26; */
    background: #69090fc4;
    background: linear-gradient(to bottom, #69090fc4, #bd1c26);
    border: none;
    border: 1px solid rgb(153, 6, 6);
    border-bottom: none;
    font-size: 2rem;
  }

  .rol-ascenso {
    border: 1px solid rgb(189, 8, 8);
    width: fit-content;
    background: #69090fc4;
    background: linear-gradient(to bottom, #69090fc4, #9c040e);

    h3 {
      border-bottom: 1px solid brown;
      padding: 0 4rem 0 2rem;
      margin-bottom: 0;
      padding-bottom: 1em;
    }
  }

  .roles {
    display: grid;
    grid-template-columns: 1.1fr repeat(4, 1fr);
    margin: 1.5rem 0 2rem;
  }

  @media (max-width: 1024px) {
    .actividades-container {
      grid-template-columns: minmax(0, 0.55fr) minmax(0, 1.25fr);
      grid-auto-flow: column;
      grid-template-rows: repeat(7, minmax(70px, auto));
    }

    .actividades-container h3 {
      padding-inline: 2rem;
      text-align: center;
    }

    .actividades-container h3 {
      font-size: 2rem;
    }
  }

  @media (max-width: 760px) {
    #roles .desktop-only {
      display: none;
    }
    .roles {
      grid-template-columns: 1fr 1fr 1fr 1fr;
      margin: 0 auto;
      width: 95%;
    }

    .role-section {
      grid-column: span 4;
    }
    .role-cell {
      width: 100%;
    }
    .roles .role-header {
      font-size: 0.7rem;
    }
    main {
      width: 97%;
    }
  }

  .role-cell {
    border: 1px solid #2f2f2f;
    padding: 0.45rem 0.55rem;
    font-size: 0.95rem;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    min-height: 42px;
    min-width: 0;
    box-sizing: border-box;
  }

  .role-header {
    font-weight: 700;
    text-transform: uppercase;
    font-size: 1.2rem;
    letter-spacing: 0.4px;
    min-height: 52px;
    overflow-wrap: anywhere;
    background: #69090fc4;
    background: linear-gradient(to bottom, #69090fc4, #9c040e);
  }

  .fusilero {
    background: #2f2f2f;
  }

  .infanteria {
    background: #3a4e31;
    background: linear-gradient(to bottom, #436d30, #3a4e31);
  }

  .caballeria {
    background: #6d5430;
    background: linear-gradient(to bottom, #6d3c30, #4b2d21);
  }

  .servicios {
    background: #237a73;
    background: linear-gradient(to bottom, #237a73, #184e50);
  }

  @media (min-width: 780px) {
    .role-section {
      grid-column: 2 / span 4;
    }
  }
  .role-name {
    grid-column: 1;
    grid-row: 2 / span 22;
    font-size: 2rem;
    font-weight: 700;
  }
  .role-section {
    font-weight: 600;
    min-height: 34px;
  }

  .role-empty {
    background-color: #111;
  }

  .role-level {
    font-weight: 600;
    background: #233133;
    border-inline: 1px solid rgb(59, 59, 59);
  }
</style>
