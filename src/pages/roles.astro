---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout>
  <Navbar
    navLinks={{
      actividades: "Horario",
      roles: "Roles",
      escalafon: "Escalafon",
    }}
    isNotFrontPage
  />

  <main>
    <section>
      <h2>Actividades durante la semana</h2>
      <div class="actividades-container" id="actividades">
        <h3>Lunes</h3>
        <h3>Martes</h3>
        <h3>Miercoles</h3>
        <h3>Jueves</h3>
        <h3>Viernes</h3>
        <h3>Sabado</h3>
        <h3>Domingo</h3>
        <h3>Entrenamientos de Armas Separadas</h3>
        <h3>Entrenamiento general + Patrulla</h3>
        <h3>Entrenamiento de Armas Conjunta</h3>
        <h3>Entrenamiento general + Patrulla</h3>
        <h3>Cursos</h3>
        <h3>Entrenamiento de Armas Separadas</h3>
        <h3>Misiones</h3>
      </div>
    </section>

    <section>
      <h2>Roles</h2>
      <p>
        Cada miembro podra pertenecer a un arma que desee, solo podra
        capacitarse y ejercer los roles de su arma correspondiente.
      </p>
      <div class="roles" id="roles">
        <div class="role-cell role-header desktop-only">Inicial</div>
        <div class="role-cell role-header">Capacitacion Rol Basico</div>
        <div class="role-cell role-header">Capacitacion Rol Experimentado</div>
        <div class="role-cell role-header">Capacitacion Rol Avanzado</div>
        <div class="role-cell role-header">Capacitacion Maestria</div>

        <div class="role-cell role-name fusilero desktop-only">Fusilero</div>
        <div class="role-cell role-section infanteria">Roles Operativos</div>

        <div class="role-cell infanteria">Explorador</div>
        <div class="role-cell infanteria">Tirador selecto</div>
        <div class="role-cell infanteria">Francotirador</div>
        <div class="role-cell infanteria">Observador</div>

        <div class="role-cell infanteria granadero-span">Granadero</div>
        <div class="role-cell infanteria">Soldado AT Ligero</div>
        <div class="role-cell infanteria">Soldado AT Pesado</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell infanteria">Soldado AA Ligero</div>
        <div class="role-cell infanteria">Soldado AA Pesado</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell infanteria">Enfermero</div>
        <div class="role-cell infanteria">Enfermero de Combate</div>
        <div class="role-cell infanteria">Medico de combate</div>
        <div class="role-cell infanteria">Medico Cirujano</div>

        <div class="role-cell infanteria">Portamuniciones</div>
        <div class="role-cell infanteria ametrallador-span">
          Ametrallador ligero
        </div>
        <div class="role-cell infanteria ametrallador-span">
          Ametrallador mediano
        </div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell infanteria">Fusilero automatico</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell infanteria">Ingeniero EOD</div>
        <div class="role-cell infanteria">Ingeniero Zapador</div>
        <div class="role-cell infanteria">Especialista en demoliciones</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell infanteria">Radio Operador de escuadra</div>
        <div class="role-cell infanteria">
          Encargado de control aereo (J.T.A.C.)
        </div>
        <div class="role-cell role-empty"></div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell role-section servicios">Roles Tecnicos</div>

        <div class="role-cell servicios">Dron de explorador</div>
        <div class="role-cell servicios">Dron de combate</div>
        <div class="role-cell role-empty"></div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell servicios">Tripulante de Mecanizada</div>
        <div class="role-cell role-empty"></div>
        <div class="role-cell servicios">Comandante de Mecanizada</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell servicios">Artillero de Movilidad Ligera</div>
        <div class="role-cell servicios">Conductor de Movilidad Ligera</div>
        <div class="role-cell servicios">Cabeza de Convoy</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell servicios">
          Operador de Dron Uav de exploracion
        </div>
        <div class="role-cell servicios">Operador de Dron Uav de Ataque</div>
        <div class="role-cell role-empty"></div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell role-level">Nivel Basico (0-50 pts) ▼</div>
        <div class="role-cell role-level">Nivel Intermedio (51-100 pts) ▼</div>
        <div class="role-cell role-level">Nivel Avanzado (101-150 pts) ▼</div>
        <div class="role-cell role-level">Nivel Maestro (151+ pts) ▼</div>

        <div class="role-cell servicios">
          Aviones de entrenamiento y reconocimiento
        </div>
        <div class="role-cell servicios">Su-25/A-29</div>
        <div class="role-cell servicios">A-10C/F-16</div>
        <div class="role-cell servicios">F-22/Mig-29</div>

        <div class="role-cell servicios">Helicopteros de transporte</div>
        <div class="role-cell servicios">AH-6 (Little bird) / UH-1Y</div>
        <div class="role-cell servicios">AH-64D/AH-1Z</div>
        <div class="role-cell servicios">UH-60 DAP / RAH-66</div>
      </div>
    </section>

    <section class="rol-info-container">
      <h2>Ascenso de Roles</h2>
      <p>
        Los roles tienen su propio sistema de ascenso, despues de completar sus
        correspondientes cantidad de actividades en su rol podra rendir su
        siguiente nivel.
      </p>
      <div class="rol-ascenso">
        <div class="ascenso-step">
          <span class="ascenso-level">Nivel Basico</span>
          <span class="ascenso-req">Ingreso</span>
        </div>
        <div class="ascenso-step">
          <span class="ascenso-level">Nivel Experimentado</span>
          <span class="ascenso-req">10 actividades</span>
        </div>
        <div class="ascenso-step">
          <span class="ascenso-level">Nivel Avanzado</span>
          <span class="ascenso-req">25 actividades</span>
        </div>
        <div class="ascenso-step">
          <span class="ascenso-level">Maestria</span>
          <span class="ascenso-req">35 actividades</span>
        </div>
      </div>
    </section>

    <section>
      <h2>Escalafon</h2>
      <p>
        Todos los nuevos miembros entraran como rango de recluta, los cuales
        tendran 4 clases de capacitacion para ascender como Aspirante
      </p>
    </section>

    <section id="escalafon">
      <h2>Escalafon</h2>
    </section>
  </main>
</Layout>

<style>
  :global(:root) {
    --bg-secondary: #a6292e;
    --text-primary: #c7191e;
    --panel-bg: #121212;
    --panel-border: rgba(199, 25, 30, 0.42);
  }

  :global(body) {
    max-width: 100vw;
    overflow-x: hidden;
    background: black;
    color: white;
    font-family:
      "Rajdhani",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }

  main {
    width: min(1200px, 92vw);
    margin: 0 auto;
    padding-top: 84px;
  }

  main section {
    margin-inline: 1vw;
    padding-bottom: 1.1rem;
    margin-bottom: 2.8rem;
    border-bottom: 1px solid rgba(128, 128, 128, 0.459);
    opacity: 0;
    transform: translateY(36px);
    animation: reveal-from-bottom 650ms ease-out both;
  }

  main section:nth-of-type(2) {
    animation-delay: 90ms;
  }

  main section:nth-of-type(3) {
    animation-delay: 180ms;
  }

  main section:nth-of-type(4) {
    animation-delay: 270ms;
  }

  main section:nth-of-type(5) {
    animation-delay: 360ms;
  }

  h2 {
    font-size: clamp(2.1rem, 2.8vw, 3.15rem);
    margin-bottom: 0.6rem;
    font-family: "Stick No Bills", sans-serif;
    font-weight: 500;
    letter-spacing: 2px;
    border-bottom: 3px solid rgba(172, 69, 69, 0.459);
    padding-left: 1.25rem;
  }

  p {
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    max-width: 70ch;
    margin-top: 0;
    line-height: 1.4;
  }

  .actividades-container {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    margin-top: 1rem;
    margin-bottom: 2.6rem;
    border: 1px solid var(--panel-border);
    border-bottom: 0;
    background: linear-gradient(
      180deg,
      rgba(18, 18, 18, 0.94),
      rgba(7, 7, 7, 0.96)
    );
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.32);
  }

  .actividades-container h3 {
    padding: 10px 8px;
    margin: 0;
    overflow-wrap: break-word;
    border: 1px solid rgba(135, 35, 35, 0.85);
    border-top: 0;
    border-left: 0;
    text-align: center;
    min-height: 72px;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(0.95rem, 1.3vw, 1.08rem);
  }

  .actividades-container h3:nth-child(-n + 7) {
    background: linear-gradient(to bottom, #69090fc4, var(--bg-secondary));
    border: 1px solid rgb(153, 6, 6);
    border-top: 0;
    font-size: clamp(1.35rem, 2vw, 1.85rem);
    font-family: "Stick No Bills", sans-serif;
    letter-spacing: 1px;
  }

  .roles {
    display: grid;
    grid-template-columns: 1.1fr repeat(4, 1fr);
    margin: 1.5rem 0 2rem;
    border: 1px solid rgba(69, 69, 69, 0.8);
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.36);
    background:
      linear-gradient(180deg, rgba(12, 12, 12, 0.877), rgba(2, 2, 2, 0.911)),
      url("/images/topographic.png");
  }

  .role-cell {
    border: 1px solid rgba(35, 35, 35, 0.92);
    padding: 0.52rem 0.58rem;
    font-size: 0.95rem;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    min-height: 44px;
    min-width: 0;
    box-sizing: border-box;
  }

  .role-header {
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(0.82rem, 1.4vw, 1.1rem);
    letter-spacing: 0.8px;
    min-height: 56px;
    overflow-wrap: anywhere;
    background: linear-gradient(to bottom, #69090fc4, #9c040e);
    text-shadow: 0 0 14px rgba(0, 0, 0, 0.55);
  }

  .fusilero {
    background:
      linear-gradient(180deg, rgba(27, 6, 6, 0.795), rgba(7, 0, 0, 0.781)),
      url("/images/topographic.png");
    background-repeat: no-repeat, repeat-x;
    background-size:
      cover,
      auto 110%;
    background-position: center;
    background-blend-mode: normal, multiply;
    color: #f1f1f1;
    text-shadow: 0 0 12px rgb(0, 0, 0);
  }

  .infanteria {
    background: linear-gradient(to bottom, #436d30, #304422);
  }

  .caballeria {
    background: linear-gradient(to bottom, #6d3c30, #4b2d21);
  }

  .servicios {
    background: linear-gradient(to bottom, #237a73, #184e50);
  }

  .rol-info-container {
    position: relative;
    padding: 1.25rem 1.25rem 1.5rem;
    border: 1px solid rgba(158, 32, 38, 0.7);
    border-radius: 6px;
    background:
      radial-gradient(
        circle at 18% 22%,
        rgba(199, 25, 30, 0.17),
        transparent 42%
      ),
      linear-gradient(180deg, rgba(17, 17, 17, 0.95), rgba(7, 7, 7, 0.98));
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.05),
      0 18px 34px rgba(0, 0, 0, 0.34);
    overflow: hidden;
  }

  .rol-info-container::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 6px;
    background: linear-gradient(to bottom, #d12b2f, #7f1115);
  }

  .rol-info-container h2 {
    margin-top: 0;
    padding-left: 1.5rem;
    border-bottom-color: rgba(185, 58, 58, 0.72);
  }

  .rol-info-container p {
    margin: 0.3rem 0 1.15rem;
    max-width: 78ch;
    color: rgba(246, 246, 246, 0.92);
    padding-left: 1.5rem;
  }

  .rol-ascenso {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    border: 1px solid rgb(189, 8, 8);
    width: 100%;
    background: linear-gradient(to right, #69090fc4, #9c040e);
    box-shadow: inset 0 18px 32px rgba(0, 0, 0, 0.33);
    overflow: hidden;
  }

  .ascenso-step {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 98px;
    padding: 0.9rem 0.75rem;
    border-right: 1px solid rgba(56, 5, 5, 0.65);
    background: linear-gradient(
      180deg,
      rgba(132, 17, 25, 0.23),
      rgba(40, 5, 8, 0.28)
    );
  }

  .ascenso-step:last-child {
    border-right: 0;
  }

  .ascenso-level {
    font-size: clamp(1.2rem, 1.9vw, 1.6rem);
    font-weight: 700;
    line-height: 1.1;
    text-align: center;
  }

  .ascenso-req {
    margin-top: 0.5rem;
    font-size: 1.2rem;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: rgba(255, 233, 233, 0.88);
    padding: 0.2rem 0.5rem;
    border: 1px solid rgba(255, 229, 229, 0.23);
    background: rgba(0, 0, 0, 0.2);
  }

  @media (min-width: 780px) {
    .role-section {
      grid-column: 2 / span 4;
    }

    .granadero-span {
      grid-row: span 2;
    }

    .ametrallador-span {
      grid-row: span 2;
    }
  }

  .role-name {
    grid-column: 1;
    grid-row: 2 / span 22;
    font-size: clamp(1.4rem, 2.2vw, 2rem);
    font-weight: 700;
    letter-spacing: 0.8px;
  }

  .role-section {
    font-weight: 700;
    min-height: 36px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }

  .role-empty {
    background: transparent;
  }

  .role-level {
    font-weight: 600;
    background: #233133;
    border-inline: 1px solid rgb(59, 59, 59);
  }

  @media (max-width: 1024px) {
    main {
      width: 96vw;
    }

    .actividades-container {
      grid-template-columns: minmax(0, 0.55fr) minmax(0, 1.25fr);
      grid-auto-flow: column;
      grid-template-rows: repeat(7, minmax(70px, auto));
    }

    .actividades-container h3 {
      padding-inline: 1.4rem;
      text-align: center;
    }
  }

  @media (max-width: 760px) {
    #roles .desktop-only {
      display: none;
    }

    .roles {
      grid-template-columns: repeat(4, 1fr);
      margin: 0 auto;
      width: 100%;
    }

    .role-section {
      grid-column: span 4;
    }

    .role-cell {
      width: 100%;
      font-size: 0.82rem;
    }

    .roles .role-header {
      font-size: 0.66rem;
      letter-spacing: 0.3px;
    }

    .rol-info-container {
      padding: 1rem 0.8rem 1.05rem;
    }

    .rol-info-container h2,
    .rol-info-container p {
      padding-left: 0.95rem;
    }

    .rol-ascenso {
      grid-template-columns: 1fr;
    }

    .ascenso-step {
      border-right: 0;
      border-bottom: 1px solid rgba(56, 5, 5, 0.65);
      padding: 0.75rem;
      min-height: 78px;
    }

    .ascenso-step:last-child {
      border-bottom: 0;
    }
  }

  @keyframes reveal-from-bottom {
    from {
      opacity: 0;
      transform: translateY(36px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    main section {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
