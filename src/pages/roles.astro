---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout>
  <Navbar
    navLinks={{
      actividades: "Horario",
      roles: "Roles",
      escalafon: "Escalafon",
    }}
    isNotFrontPage
  />

  <main>
    <section>
      <h2>Actividades durante la semana</h2>
      <div class="actividades-container" id="actividades">
        <div class="days">
          <h3>Lunes</h3>
          <h3>Martes</h3>
          <h3>Miercoles</h3>
          <h3>Jueves</h3>
          <h3>Viernes</h3>
          <h3>Sabado</h3>
          <h3>Domingo</h3>
        </div>
        <div>
          <h3>Entrenamiento Tactico</h3>
          <h3>Entrenamiento Roles</h3>
          <h3>Patrulla</h3>
          <h3>Entrenamiento Roles</h3>
          <h3>Patrulla</h3>
          <h3>Entrenamiento Tactico</h3>
          <h3>Misiones</h3>
        </div>
      </div>
    </section>

    <section>
      <h2>Roles</h2>
      <p>
        Cada miembro puede elegir capacitarse en el rol que desee. Una vez capacitado podra desempenar ese rol en las actividades, todos los roles tienen diferentes niveles de capacitacion.
      </p>
      <div class="roles" id="roles">
        <div class="role-cell role-header desktop-only">Inicial</div>
        <div class="role-cell role-header">Capacitacion Rol Basico</div>
        <div class="role-cell role-header">Capacitacion Rol Experimentado</div>
        <div class="role-cell role-header">Capacitacion Rol Avanzado</div>
        <div class="role-cell role-header">Capacitacion Maestria</div>

        <div class="role-cell role-name fusilero desktop-only">Fusilero</div>
        <div class="role-cell role-section infanteria">Roles Operativos</div>

        <div class="role-cell infanteria">Explorador</div>
        <div class="role-cell infanteria">Tirador selecto</div>
        <div class="role-cell infanteria">Francotirador</div>
        <div class="role-cell infanteria">Observador</div>

        <div class="role-cell infanteria granadero-span">Granadero</div>
        <div class="role-cell infanteria">Soldado AT Ligero</div>
        <div class="role-cell infanteria">Soldado AT Pesado</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell infanteria">Soldado AA Ligero</div>
        <div class="role-cell infanteria">Soldado AA Pesado</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell infanteria">Enfermero</div>
        <div class="role-cell infanteria">Enfermero de Combate</div>
        <div class="role-cell infanteria">Medico de combate</div>
        <div class="role-cell infanteria">Medico Cirujano</div>

        <div class="role-cell infanteria">Portamuniciones</div>
        <div class="role-cell infanteria ametrallador-span">
          Ametrallador ligero
        </div>
        <div class="role-cell infanteria ametrallador-span">
          Ametrallador mediano
        </div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell infanteria">Fusilero automatico</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell infanteria">Ingeniero EOD</div>
        <div class="role-cell infanteria">Ingeniero Zapador</div>
        <div class="role-cell infanteria">Especialista en demoliciones</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell infanteria">Radio Operador de escuadra</div>
        <div class="role-cell infanteria">
          Encargado de control aereo (J.T.A.C.)
        </div>
        <div class="role-cell role-empty"></div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell role-section servicios">Roles Tecnicos</div>

        <div class="role-cell servicios">Dron de explorador</div>
        <div class="role-cell servicios">Dron de combate</div>
        <div class="role-cell role-empty"></div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell servicios">Tripulante de Mecanizada</div>
        <div class="role-cell role-empty"></div>
        <div class="role-cell servicios">Comandante de Mecanizada</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell servicios">Artillero de Movilidad Ligera</div>
        <div class="role-cell servicios">Conductor de Movilidad Ligera</div>
        <div class="role-cell servicios">Cabeza de Convoy</div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell servicios">
          Operador de Dron Uav de exploracion
        </div>
        <div class="role-cell servicios">Operador de Dron Uav de Ataque</div>
        <div class="role-cell role-empty"></div>
        <div class="role-cell role-empty"></div>

        <div class="role-cell role-level">Nivel Basico (0-50 pts) ▼</div>
        <div class="role-cell role-level">Nivel Intermedio (51-100 pts) ▼</div>
        <div class="role-cell role-level">Nivel Avanzado (101-150 pts) ▼</div>
        <div class="role-cell role-level">Nivel Maestro (151+ pts) ▼</div>

        <div class="role-cell servicios">
          Aviones de entrenamiento y reconocimiento
        </div>
        <div class="role-cell servicios">Su-25/A-29</div>
        <div class="role-cell servicios">A-10C/F-16</div>
        <div class="role-cell servicios">F-22/Mig-29</div>

        <div class="role-cell servicios">Helicopteros de transporte</div>
        <div class="role-cell servicios">AH-6 (Little bird) / UH-1Y</div>
        <div class="role-cell servicios">AH-64D/AH-1Z</div>
        <div class="role-cell servicios">UH-60 DAP / RAH-66</div>
      </div>
    </section>

    <section class="rol-info-container">
      <h2>Ascenso de Roles</h2>
      <p>
        Cada rol cuenta con su propio sistema de progreso. Al completar la
        cantidad de actividades requerida, podras rendir la evaluacion para
        avanzar al siguiente nivel.
      </p>
      <div class="rol-ascenso">
        <div class="ascenso-step">
          <span class="ascenso-level">Nivel Basico</span>
          <span class="ascenso-req">Ingreso</span>
        </div>
        <div class="ascenso-step">
          <span class="ascenso-level">Nivel Experimentado</span>
          <span class="ascenso-req">10 actividades</span>
        </div>
        <div class="ascenso-step">
          <span class="ascenso-level">Nivel Avanzado</span>
          <span class="ascenso-req">25 actividades</span>
        </div>
        <div class="ascenso-step">
          <span class="ascenso-level">Maestria</span>
          <span class="ascenso-req">35 actividades</span>
        </div>
      </div>
    </section>

    <section>
      <h2 id="escalafon">Escalafon</h2>
      <p>
        La estructura de mando se organiza en tres ramas. Todo nuevo miembro
        inicia como Recluta y asciende segun su rendimiento, compromiso y
        cumplimiento en entrenamientos, patrullas y misiones.
      </p>
      <div class="escalafon">
        <article class="escalafon-card oficiales">
          <h3>Oficiales</h3>
          <ul>
            <li>Director</li>
            <li>Coordinador de Equipos</li>
          </ul>
        </article>

        <article class="escalafon-card suboficiales">
          <h3>Suboficiales</h3>
          <ul>
            <li>Auxiliar Tactico</li>            
            <li>Jefe de Equipo</li>
            <li>Segundo Jefe de Equipo</li>
          </ul>
        </article>

        <article class="escalafon-card tropa">
          <h3>Tropa</h3>
          <ul>
            <li>Operador Senior</li>
            <li>Operador</li>
            <li>Operador Junior</li>
            <li>Recluta</li>
          </ul>
        </article>
      </div>
    </section>
  </main>
</Layout>

<style>
  :global(:root) {
    --bg-secondary: #a6292e;
    --text-primary: #c7191e;
    --surface-1: rgba(14, 14, 14, 0.9);
    --surface-2: rgba(8, 8, 8, 0.92);
    --line-soft: rgba(255, 120, 120, 0.22);
    --line-strong: rgba(201, 24, 16, 0.46);
  }

  :global(*) {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :global(body) {
    max-width: 100vw;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 14% 10%, rgba(166, 20, 20, 0.24), transparent 32%),
      radial-gradient(circle at 84% 8%, rgba(255, 34, 34, 0.14), transparent 30%),
      linear-gradient(160deg, #050505 0%, #0d0808 46%, #030202 100%);
    color: white;
    font-family:
      "Rajdhani",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }

  main {
    width: min(1280px, 94vw);
    margin: 0 auto;
    padding-top: 8rem;
    padding-bottom: 2rem;
    position: relative;
  }

  main::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 24px 24px;
    opacity: 0.35;
    z-index: 0;
  }

  main > * {
    position: relative;
    z-index: 1;
  }

  main section {
    position: relative;
    margin-inline: clamp(0.2rem, 1vw, 0.85rem);
    padding: 1.2rem 1.1rem 1.25rem;
    margin-bottom: 2rem;
    border: 1px solid var(--line-soft);
    border-radius: 6px;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.03),
      0 16px 34px rgba(0, 0, 0, 0.35);
    background:
      linear-gradient(170deg, var(--surface-1), var(--surface-2)),
      url("/images/topographic.png");
    background-size: cover, auto 145%;
    background-position: center, center;
    background-blend-mode: normal, screen;
    overflow: hidden;
    opacity: 0;
    transform: translateY(36px);
    animation: reveal-from-bottom 650ms ease-out both;
  }

  main section::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 5px;
    background: linear-gradient(to bottom, #d12b2f, #7f1115);
    pointer-events: none;
  }

  h2 {
    font-size: clamp(2.15rem, 3.8vw, 3.25rem);
    margin: 0 0 0.55rem;
    padding-bottom: 0;
    font-family: "Stick No Bills", sans-serif;
    letter-spacing: 1px;
    text-transform: uppercase;
    border-bottom: 1px solid rgba(255, 87, 87, 0.32);
    text-align: center;
  }

  p {
    font-size: clamp(1.06rem, 1.65vw, 1.35rem);
    max-width: 78ch;
    margin: 0.2rem auto 1rem;
    line-height: 1.36;
    color: rgba(246, 246, 246, 0.9);
  }

  .actividades-container {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    grid-template-rows: repeat(2, minmax(72px, auto));
    margin-top: 1rem;
    margin-bottom: 0.6rem;
    border: 1px solid var(--line-strong);
    border-bottom: 0;
    border-radius: 4px;
    overflow: hidden;
    background: linear-gradient(
      180deg,
      rgba(18, 18, 18, 0.94),
      rgba(7, 7, 7, 0.96)
    );
    box-shadow: 0 16px 30px rgba(0, 0, 0, 0.3);
  }
  .actividades-container div {
    display: contents;
  }

  .actividades-container h3 {
    width: 100%;
    padding: 10px 8px;
    margin: 0;
    overflow-wrap: break-word;
    border: 1px solid rgba(135, 35, 35, 0.72);
    border-top: 0;
    border-left: 0;
    text-align: center;
    min-height: 72px;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(1.02rem, 1.28vw, 1.24rem);
  }

  .actividades-container .days {
    font-size: 1.5rem;
    font-family: "Stick No Bills", sans-serif;
    letter-spacing: 1px;
  }

  .actividades-container .days h3 {
    background: linear-gradient(to bottom, #69090fc4, var(--bg-secondary));
    border-color: rgb(153, 6, 6);
  }

  .roles {
    display: grid;
    grid-template-columns: 1.1fr repeat(4, 1fr);
    margin: 1.5rem 0 2rem;
    border: 1px solid rgba(96, 96, 96, 0.56);
    box-shadow: 0 18px 32px rgba(0, 0, 0, 0.34);
    background:
      linear-gradient(180deg, rgba(12, 12, 12, 0.877), rgba(2, 2, 2, 0.911)),
      url("/images/topographic.png");
    overflow: hidden;
  }

  .role-cell {
    border: 1px solid rgba(35, 35, 35, 0.92);
    padding: 0.52rem 0.58rem;
    font-size: 0.92rem;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    min-height: 44px;
    min-width: 0;
    box-sizing: border-box;
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .role-cell:hover {
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
  }

  .role-header {
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(0.82rem, 1.4vw, 1.1rem);
    letter-spacing: 0.7px;
    min-height: 56px;
    overflow-wrap: anywhere;
    background: linear-gradient(to bottom, #69090fc4, #9c040e);
    text-shadow: 0 0 14px rgba(0, 0, 0, 0.55);
  }

  .fusilero {
    background: transparent;
    color: #f1f1f1;
    text-shadow: 0 0 12px rgb(82, 81, 81);
  }

  .infanteria {
    background: linear-gradient(to bottom, #436d30, #304422);
  }

  .caballeria {
    background: linear-gradient(to bottom, #6d3c30, #4b2d21);
  }

  .servicios {
    background: linear-gradient(to bottom, #237a73, #184e50);
  }

  .rol-info-container {
    padding-bottom: 1em;
  }

  .rol-info-container h2 {
    margin-top: 0;
  }

  .rol-info-container p {
    margin: 0.3rem 0 1.15rem;
    max-width: 78ch;
    color: rgba(246, 246, 246, 0.92);
  }

  .rol-ascenso {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    border: 1px solid rgb(189, 8, 8);
    width: 100%;
    background: linear-gradient(to right, #69090fc4, #9c040e);
    box-shadow: inset 0 18px 32px rgba(0, 0, 0, 0.33);
    overflow: hidden;
  }

  .ascenso-step {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 98px;
    padding: 0.9rem 0.75rem;
    border-right: 1px solid rgba(56, 5, 5, 0.65);
    background: linear-gradient(
      180deg,
      rgba(132, 17, 25, 0.23),
      rgba(40, 5, 8, 0.28)
    );
  }

  .ascenso-step:last-child {
    border-right: 0;
  }

  .ascenso-level {
    font-size: clamp(1.2rem, 1.9vw, 1.6rem);
    font-weight: 700;
    line-height: 1.1;
    text-align: center;
  }

  .ascenso-req {
    margin-top: 0.5rem;
    font-size: 1.2rem;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: rgba(255, 233, 233, 0.88);
    padding: 0.2rem 0.5rem;
    border: 1px solid rgba(255, 229, 229, 0.23);
    background: rgba(0, 0, 0, 0.2);
  }


  .escalafon {
    margin-top: 1.1rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.9rem;
  }

  .escalafon-card {
    border: 3px solid rgba(255, 255, 255, 0.16);
    box-shadow:
      inset 0 0 0 12px 1rem rgba(19, 19, 19, 0.547),
      0 10px 24px rgba(0, 0, 0, 0.28);
    padding: 0.9rem 0.9rem 1rem;
    min-height: 100%;
    width: 50%;
    margin: 0 auto;
  }

  .escalafon-card h3 {
    text-align: center;
    font-size: clamp(2.45rem, 2.4vw, 2rem);
    font-family: "Stick No Bills", sans-serif;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 0.62rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.24);
    text-shadow: 0 0 8px rgb(41, 41, 41);
  }

  .escalafon-card ul {
    list-style: none;
    display: grid;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
  }

  .escalafon-card li {
    border: 1px solid rgba(0, 0, 0, 0.3);
    background: rgba(0, 0, 0, 0.2);
    padding: 0.45rem 0.55rem;
    text-align: center;
    font-size: 2rem;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease;
  }

  .escalafon-card li:hover {
    background: rgba(0, 0, 0, 0.3);
    border-color: rgba(255, 255, 255, 0.26);
  }

  .tropa {
    background: linear-gradient(to bottom, #184e50, #237a73);
  }

  .suboficiales {
    background: linear-gradient(to bottom, #304422, #436d30);
  }

  .oficiales {
    background: linear-gradient(to bottom, #583c1a, #907f23);
  }
  @media (min-width: 780px) {
    .role-section {
      grid-column: 2 / span 4;
    }

    .granadero-span {
      grid-row: span 2;
    }

    .ametrallador-span {
      grid-row: span 2;
    }
  }

  .role-name {
    grid-column: 1;
    grid-row: 2 / span 22;
    font-size: clamp(1.4rem, 2.2vw, 2rem);
    font-weight: 700;
    letter-spacing: 0.8px;
  }

  .role-section {
    font-weight: 700;
    min-height: 36px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }

  .role-empty {
    background: transparent;
  }

  .role-level {
    font-weight: 600;
    background: #233133;
    border-inline: 1px solid rgb(59, 59, 59);
  }

  .role-level:hover {
    background: #2a3c3f;
  }

  @media (max-width: 1024px) {
    main {
      width: min(1280px, 96vw);
    }

    .actividades-container {
      grid-template-columns: minmax(0, 0.7fr) minmax(0, 1.3fr);
      grid-template-rows: repeat(7, minmax(70px, auto));
      grid-auto-flow: column;
    }

    .actividades-container h3 {
      padding-inline: 1rem;
      text-align: left;
      justify-content: flex-start;
    }
  }

  @media (max-width: 760px) {
    #roles .desktop-only {
      display: none;
    }

    main section {
      margin-inline: 0.4rem;
      padding: 0.95rem 0.78rem 1rem;
      margin-bottom: 2.1rem;
    }

    h2,
    p {
      padding-left: 0;
    }

    .actividades-container {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(14, minmax(62px, auto));
      grid-auto-flow: row;
    }

    .actividades-container h3 {
      font-size: 1.05rem;
      text-align: center;
      justify-content: center;
    }

    .roles {
      grid-template-columns: repeat(4, 1fr);
      margin: 0.5rem auto 0.1rem;
      width: 100%;
    }

    .escalafon {
      grid-template-columns: 1fr;
      gap: 0.65rem;
    }

    .escalafon-card {
      padding: 0.78rem 0.72rem 0.85rem;
    }

    .escalafon-card h3 {
      font-size: 1.45rem;
      margin-bottom: 0.45rem;
    }

    .escalafon-card li {
      font-size: 0.92rem;
      padding: 0.4rem 0.45rem;
    }

    .role-section {
      grid-column: span 4;
    }

    .role-cell {
      width: 100%;
      font-size: 0.8rem;
    }

    .roles .role-header {
      font-size: 0.68rem;
      letter-spacing: 0.3px;
    }

    .rol-info-container {
      padding-bottom: 1em;
    }

    .rol-info-container h2,
    .rol-info-container p {
      padding-left: 0;
    }

    .rol-ascenso {
      grid-template-columns: 1fr;
    }

    .ascenso-step {
      border-right: 0;
      border-bottom: 1px solid rgba(56, 5, 5, 0.65);
      padding: 0.75rem;
      min-height: 78px;
    }

    .ascenso-step:last-child {
      border-bottom: 0;
    }
  }

  @keyframes reveal-from-bottom {
    from {
      opacity: 0;
      transform: translateY(36px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    main section {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
