---
const date = new Date();
const currentYear = date.getFullYear();

import { Image } from "astro:assets";
import logo from "../../public/images/logo.png";
---

<footer id="footer">
  <div class="footer-container">
    <div class="footer-brand">
      <span class="footer-eyebrow">Clan MILSIM Arma 3</span>
      <div class="footer-heading">
        <Image src={logo} alt="Clan Logo" height="120" />
        <div>
          <h2>Comando 99</h2>
          <p>
            Un servidor MILSIM de Arma 3 que fomenta una cultura seria y
            responsable para jugadores que buscan realismo, camaraderia y
            profesionalidad.
          </p>
        </div>
      </div>
      <div class="footer-tags" aria-label="Valores del grupo">
        <span>Operaciones</span>
        <span>Disciplina</span>
        <span>Comunidad</span>
      </div>
    </div>
    <div class="footer-side">
      <nav class="footer-links" aria-label="Navegacion del pie de pagina">
        <a href="/">Inicio</a>
        <a href="/roles">Roles</a>
        <a href="/galeriaCompleta">Galeria</a>
        <a class="discord-link" href="https://discord.com/invite/UJUp2cWtwp"
          >Discord</a
        >
      </nav>
      <p class="copyright">
        © {currentYear} Comando 99 grupo de simulacion militar.
        <br />
        No afiliado con Bohemia Interactive.
      </p>
    </div>
  </div>
</footer>

<style>
  footer {
    position: relative;
    width: 100%;
    margin-top: 0;
    padding: clamp(1.5rem, 2vw, 3rem) clamp(1rem, 4vw, 3rem);
    background:
      radial-gradient(circle at 50% 0%, rgba(75, 73, 73, 0.2), transparent 40%),
      linear-gradient(180deg, #090909 0%, #020202 100%);
    border-top: 1px solid rgba(201, 24, 16, 0.28);
    overflow: hidden;
  }

  footer::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.06) 50%),
      linear-gradient(90deg, rgba(255, 0, 0, 0.01), rgba(0, 0, 0, 0.01));
    background-size:
      100% 2px,
      3px 100%;
    opacity: 0.35;
  }

  .footer-container {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.95fr);
    gap: 1.25rem;
    align-items: stretch;
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-brand,
  .footer-side {
    overflow: hidden;
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .footer-eyebrow {
    display: inline-block;
    margin-bottom: 1rem;
    color: #ff2a1c;
    font-family: "Rajdhani", sans-serif;
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    border-bottom: 1px solid rgba(201, 24, 16, 0.7);
    padding-bottom: 0.2rem;
    width: 100%;
    text-align: center;
  }

  .footer-heading {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: center;
  }

  .footer-heading :global(img) {
    width: clamp(4.75rem, 10vw, 7rem);
    height: auto;
    filter: drop-shadow(0 1rem 1.6rem rgba(0, 0, 0, 0.55));
  }

  .footer-heading h2 {
    margin: 0;
    font-family: "Stick No Bills", sans-serif;
    font-size: clamp(2.1rem, 4vw, 3rem);
    line-height: 0.95;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .footer-heading p {
    max-width: 46ch;
    margin: 0.75rem 0 0;
    color: rgba(255, 255, 255, 0.76);
    font-family: "Rajdhani", sans-serif;
    font-size: 1rem;
    line-height: 1.55;
  }

  .footer-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .footer-tags span {
    display: inline-flex;
    align-items: center;
    min-height: 2.2rem;
    padding: 0.45rem 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(16, 16, 16, 0.8);
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    font-family: "Rajdhani", sans-serif;
    text-transform: uppercase;
  }

  .footer-side {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .footer-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.8rem 1rem;
    border: 1px solid transparent;
    background: rgba(18, 18, 18, 0.8);
    color: rgba(255, 255, 255, 0.84);
    border-color: rgba(255, 255, 255, 0.58);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.3rem;
    font-size: 1.02rem;
    font-weight: 600;
    font-family: "Rajdhani", sans-serif;
    font-style: italic;
    transition:
      transform 0.18s ease,
      color 0.2s ease,
      text-shadow 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .footer-links a:hover {
    color: #ff0000;
    text-shadow: 0 0 0.75rem rgba(201, 24, 16, 0.45);
    background: rgba(121, 5, 5, 0.78);
    border-color: red;
    box-shadow: 0 0.8rem 1.2rem rgba(0, 0, 0, 0.28);
  }

  .footer-links a:focus-visible {
    outline: 2px solid rgba(255, 39, 24, 0.95);
    outline-offset: 2px;
  }

  .footer-links .discord-link {
    border-color: rgba(185, 15, 8, 0.85);
    background: linear-gradient(135deg, #b90f08, #dd2216);
    box-shadow: 0 0 1.1rem rgba(180, 16, 8, 0.28);
    color: #fff;
    font-weight: 800;
    letter-spacing: 0.14em;
  }

  .footer-links .discord-link:hover {
    transform: translateY(-1px);
    background: linear-gradient(135deg, #d31911, #f43627);
    color: #fff;
    text-shadow: none;
    border-color: rgba(255, 80, 62, 0.95);
  }

  .copyright {
    margin: 0;
    padding-top: 0.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.5);
    font-family: "Rajdhani", sans-serif;
    letter-spacing: 0.03em;
    font-size: 0.95rem;
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .footer-container {
      grid-template-columns: 1fr;
    }

    .footer-side {
      gap: 1rem;
    }
  }

  @media (max-width: 640px) {
    footer {
      padding-inline: 1rem;
    }

    .footer-heading {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
    }

    .footer-heading p {
      text-align: center;
    }

    .footer-tags {
      justify-content: center;
    }

    .footer-links {
      grid-template-columns: 1fr;
    }
  }
</style>
