---
import { Image } from "astro:assets";
import logo from "../../public/images/logo.png";
import Summary from "./Summary.astro";
---

<main>
  <section class="hero" id="hero">
    <div class="hero__shade"></div>
    <div class="hero__content">
      <span class="hero__eyebrow">Fase de reclutamiento: Abierta</span>
      <h1>
        Excelencia<br />
        <span>Tactica.</span>
      </h1>
      <p>
        Comando 99 es una comunidad milsim de Arma 3 dedicada a recrear
        operaciones militares con realismo, disciplina y trabajo en equipo.
      </p>
      <div class="cta">
        <a href="https://discord.com/invite/UJUp2cWtwp" class="cta-call">
          Nuestro Discord
        </a>
        <a href="#showcase" class="cta-secondary">Mas Informacion</a>
      </div>
    </div>
    <Image
      src={logo}
      alt="Comando 99 insignia"
      class="hero__badge"
      loading="eager"
    />
    <Summary />
  </section>
</main>

<style>
  main {
    position: relative;
    background: #050505;
  }

  .hero {
    position: relative;
    min-height: 100vh;
    width: 100%;
    margin-inline: 0;
    margin-bottom: 0;
    padding: 30dvh 7rem 0;
    overflow: hidden;
    isolation: isolate;
    background:
      linear-gradient(
        90deg,
        rgba(0, 0, 0, 0.801) 0%,
        rgba(0, 0, 0, 0.397) 34%,
        rgba(0, 0, 0, 0) 45%,
        rgba(0, 0, 0, 0) 100%
      ),
      radial-gradient(
        circle at 58% 50%,
        rgba(255, 62, 36, 0.151),
        transparent 30%
      ),
      url("/images/hero-bg.png");
    background-position:
      center,
      center,
      right center;
    background-repeat: no-repeat;
    background-size: cover, cover, cover;
  }

  .hero__shade {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        rgba(0, 0, 0, 0.4),
        transparent 25%,
        transparent 75%,
        rgba(0, 0, 0, 0.7)
      ),
      linear-gradient(90deg, rgba(0, 0, 0, 0.4), transparent 35%);
    z-index: -1;
  }

  .hero__eyebrow {
    display: inline-block;
    margin-bottom: 1.25rem;
    color: #ff4b36;
    font-family: "Rajdhani", sans-serif;
    font-size: clamp(0.8rem, 1.2vw, 1rem);
    font-weight: 600;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  h1 {
    font-family:
      "Stick No Bills",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
    text-transform: uppercase;
    font-size: clamp(3.8rem, 7vw, 8rem);
    line-height: 0.88;
    letter-spacing: 0.04em;
    margin: 0;
    text-wrap: balance;
  }

  h1 span {
    color: #c91810;
  }

  .hero p {
    max-width: 30rem;
    margin: 1.5rem 0 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: clamp(1rem, 1.7vw, 1.45rem);
    line-height: 1.5;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    margin-bottom: 6dvh;
  }

  .hero__badge {
    position: absolute;
    z-index: 1;
    top: 50%;
    left: 55%;
    width: clamp(14rem, 33vw, 34rem);
    height: auto;
    transform: translate(-50%, -48%);
    opacity: 0.87;
    filter: drop-shadow(0 1.5rem 3rem rgba(0, 0, 0, 0.65));
    pointer-events: none;
  }

  a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 11rem;
    border: 1px solid rgba(255, 255, 255, 0.28);
    color: inherit;
    text-decoration: none;
    padding: 0.95rem 1.6rem;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease,
      color 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    font-size: 0.95rem;
  }

  .cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  .cta-call {
    border-color: transparent;
    background: linear-gradient(135deg, #b90f08, #dd2216);
    box-shadow: 0 0 1.4rem rgba(180, 16, 8, 0.35);
  }

  .cta-secondary {
    background: rgba(10, 10, 10, 0.38);
    backdrop-filter: blur(2px);
  }

  .cta a:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 73, 47, 0.8);
  }

  .cta-call:hover {
    background: linear-gradient(135deg, #d31911, #f43627);
  }

  .cta-secondary:hover {
    background: rgba(130, 12, 6, 0.25);
  }

  @media (max-width: 1024px) {
    .hero {
      align-items: flex-end;
      min-height: auto;
      padding-top: 7rem;
      padding-bottom: 4rem;
      background-position: 72% center;
    }

    h1 {
      font-size: clamp(3.8rem, 14vw, 6rem);
    }

    .hero p {
      font-size: clamp(1rem, 4vw, 1.35rem);
    }

    .cta {
      flex-direction: column;
    }

    .cta a {
      width: 100%;
      font-size: 1rem;
      padding: 1rem 1.25rem;
    }

    .hero__badge {
      top: auto;
      bottom: 3rem;
      left: auto;
      right: 1.5rem;
      width: min(32vw, 11rem);
      transform: none;
      opacity: 0.82;
    }
  }

  @media (max-width: 720px) {
    .hero {
      padding-inline: 8vw;
      min-height: 100svh;
      align-items: flex-start;
      padding-top: 15vh;
      background:
        linear-gradient(
          180deg,
          rgba(0, 0, 0, 0.5) 0%,
          rgba(0, 0, 0, 0.74) 52%,
          rgba(0, 0, 0, 0.94) 100%
        ),
        linear-gradient(
          90deg,
          rgba(0, 0, 0, 0.88) 0%,
          rgba(0, 0, 0, 0.5) 50%,
          rgba(0, 0, 0, 0.2) 100%
        ),
        url("/images/hero-bg.png");
      background-repeat: no-repeat;
      background-size: cover;
      background-position: 68% center;
    }

    .hero__eyebrow {
      letter-spacing: 0.24em;
    }

    .hero__content {
      width: 100%;
      max-width: 100%;
    }

    .hero__badge {
      right: 25%;
      bottom: 3%;
      width: 50vw;
    }
  }
</style>
