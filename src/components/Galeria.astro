---
import { Image } from "astro:assets";

const images = import.meta.glob("/public/images/galeria/*.*", { eager: true });
const imagePaths = Object.keys(images).map((path) =>
  path.replace("/public", ""),
);
---

<section class="galeria" id="gallery">
  <h2>Galeria</h2>
  <div class="gallery-list collapsed">
    {
      imagePaths.slice(0, 18).map((item, index) => {
        const filename = item.split("/").pop()?.split(".")[0] || "imagen";
        return (
          <div class="gallery-item">
            <Image
              src={item}
              alt={`Comando 99 - ${filename}`}
              width={800}
              height={200}
              loading={index < 3 ? "eager" : "lazy"}
              decoding="async"
              fetchpriority={index === 0 ? "high" : "low"}
            />
          </div>
        );
      })
    }
  </div>
  <div class="gallery-modal" aria-hidden="true">
    <button class="gallery-modal-close" aria-label="Cerrar">&times;</button>
    <img class="gallery-modal-image" alt="" />
  </div>
  <div class="gallery-options">
    <button class="galeria-btn"
      >Ver mas fotos <i class="fas fa-chevron-down navigation-chevron"
      ></i></button
    >
    <a href="/galeriaCompleta">Ver Galeria completa</a>
  </div>
</section>

<style>
  .galeria {
    position: relative;
    margin-inline: 0;
    margin-top: 0;
    padding: clamp(2rem, 4vw, 3rem) clamp(1rem, 4vw, 3rem);
    min-height: 200px;
    background:
      radial-gradient(
        circle at 50% 0%,
        rgba(201, 24, 16, 0.12),
        transparent 34%
      ),
      linear-gradient(180deg, #080808 0%, #050505 100%);
    border-block: 1px solid rgba(201, 24, 16, 0.28);
    overflow: hidden;
  }

  .galeria::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.08) 50%),
      linear-gradient(
        90deg,
        rgba(255, 0, 0, 0.014),
        rgba(0, 255, 0, 0.008),
        rgba(0, 0, 255, 0.014)
      );
    background-size:
      100% 2px,
      3px 100%;
    opacity: 0.55;
  }

  .galeria h2 {
    position: relative;
    z-index: 1;
    text-align: center;
    margin-bottom: 1rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid rgba(201, 24, 16, 0.34);
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-shadow: 0 0 1rem rgba(201, 24, 16, 0.18);
  }
  .gallery-list {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-bottom: 0;
    padding-top: 1rem;
    transition: 0.5s;
  }

  @media (min-width: 768px) {
    .gallery-list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .gallery-list.collapsed {
    display: grid;
  }

  .gallery-list.collapsed .gallery-item:nth-child(n + 4) {
    display: none;
  }
  .gallery-item {
    position: relative;
    overflow: hidden;
    max-height: 1000px;
    border: 1px solid rgba(255, 175, 110, 0.18);
    background: #090909;
    transform: translateY(0);
    box-shadow:
      0 1rem 1.8rem rgba(0, 0, 0, 0.34),
      inset 0 0 0 1px rgba(255, 255, 255, 0.02);
    transition:
      max-height 0.5s,
      opacity 0.5s,
      transform 0.28s ease,
      border-color 0.28s ease,
      box-shadow 0.28s ease;
  }

  .gallery-item::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 85% 12%,
      rgba(245, 118, 95, 0.329),
      transparent 52%
    );
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
    z-index: 2;
  }

  .gallery-item::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(9, 8, 8, 0.92) 5%,
      rgba(9, 8, 8, 0.15) 48%,
      transparent 74%
    );
    opacity: 0.85;
    transition: opacity 0.2s;
    pointer-events: none;
    z-index: 1;
  }

  .gallery-item img {
    width: 100%;
    height: auto;
    object-fit: cover;
    aspect-ratio: 16/9;
    transition:
      transform 0.45s ease,
      filter 0.35s ease;
    display: block;
    filter: saturate(92%);
  }

  .gallery-item:hover {
    transform: translateY(-6px);
    border-color: rgba(255, 111, 111, 0.5);
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.5);
  }

  .gallery-item:hover::before {
    opacity: 1;
  }

  .gallery-item:hover::after {
    opacity: 1;
  }

  .gallery-item:hover img {
    cursor: pointer;
    transform: scale(1.05);
    filter: saturate(108%);
  }

  .gallery-list:hover .gallery-item:not(:hover) {
    opacity: 0.84;
  }

  .gallery-modal {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: rgba(0, 0, 0, 0.88);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.2s,
      visibility 0.2s;
    z-index: 9999;
  }

  .gallery-modal.is-open {
    opacity: 1;
    visibility: visible;
  }

  .gallery-modal-image {
    max-width: 92vw;
    max-height: 92vh;
    object-fit: contain;
    border: 1px solid rgba(201, 24, 16, 0.35);
    box-shadow:
      0 10px 40px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.02);
  }

  .gallery-modal-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-size: 36px;
    line-height: 1;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    color: white;
    background: rgba(75, 0, 0, 0.8);
    cursor: pointer;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease;
  }

  .gallery-modal-close:hover {
    transform: translateY(-1px);
    background: rgba(125, 7, 7, 0.95);
  }

  .gallery-options {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    justify-content: space-around;
    margin-top: 1rem;
    width: 100%;
    margin: 0 auto;
    border-top: 1px solid rgba(201, 24, 16, 0.28);
    padding-top: 1rem;
    position: relative;
    z-index: 1;
  }

  .gallery-options a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.03);
  }
  .gallery-options button {
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: linear-gradient(135deg, #b90f08, #dd2216);
    font-family: inherit;
    padding: 0.85rem 1.25rem;
    box-shadow: 0 0.85rem 1.5rem rgba(180, 16, 8, 0.22);
  }

  .galeria-btn,
  .gallery-options a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: inherit;
    text-decoration: none;
    font-size: 1.25rem;
    text-align: center;
    width: 100%;
    min-height: 3.15rem;
    padding: 0.85rem 1rem;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      color 0.2s ease;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;

    &:hover {
      border-color: rgb(197, 7, 7);
    }
  }

  .galeria-btn {
    gap: 0.5rem;
    color: white;
  }

  .gallery-options button:hover {
    background: linear-gradient(135deg, #d31911, #f43627);
    box-shadow: 0 1rem 1.75rem rgba(180, 16, 8, 0.32);
    transform: translateY(-1px);
  }
  .gallery-options a:hover {
    background-color: rgba(87, 18, 18, 0.96);
    transform: translateY(-1px);
    box-shadow: 0 0.85rem 1.5rem rgba(0, 0, 0, 0.2);
  }

  .gallery-options button:focus-visible,
  .gallery-options a:focus-visible {
    outline: 2px solid rgba(255, 90, 70, 0.95);
    outline-offset: 2px;
  }

  button:disabled {
    background: #270303;
    color: #534040;
    cursor: not-allowed;
  }
</style>
<script>
  const photoList = document.querySelector(".gallery-list");
  const button = document.querySelector(".galeria-btn") as HTMLButtonElement;
  const modal = document.querySelector(".gallery-modal");
  const modalImage = document.querySelector(
    ".gallery-modal-image",
  ) as HTMLImageElement;
  const modalClose = document.querySelector(
    ".gallery-modal-close",
  ) as HTMLButtonElement;

  const openModal = (src: string, alt: string) => {
    if (!modal || !modalImage) return;
    modalImage.src = src;
    modalImage.alt = alt || "";
    modal.classList.add("is-open");
    modal.setAttribute("aria-hidden", "false");
  };

  const closeModal = () => {
    if (!modal || !modalImage) return;
    modal.classList.remove("is-open");
    modal.setAttribute("aria-hidden", "true");
    modalImage.src = "";
  };

  photoList?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLImageElement)) return;
    openModal(target.currentSrc || target.src, target.alt);
  });

  modalClose?.addEventListener("click", closeModal);
  modal?.addEventListener("click", (event) => {
    if (event.target === modal) closeModal();
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeModal();
  });

  button?.addEventListener("click", () => {
    const isCollapsed = photoList?.classList.contains("collapsed");

    if (isCollapsed) {
      photoList?.classList.remove("collapsed");
      button.innerHTML =
        "Ver menos fotos <i class='fas fa-chevron-up navigation-chevron'></i>";
    } else {
      photoList?.classList.add("collapsed");
      button.innerHTML =
        "Ver mas fotos <i class='fas fa-chevron-down navigation-chevron'></i>";
    }
  });
</script>
