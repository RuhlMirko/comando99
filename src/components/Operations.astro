---
import { Image } from "astro:assets";

const allGalleryImages = import.meta.glob("/public/images/galeria/**/*.*", {
  eager: true,
});

const firstImageFrom = (folder: string) => {
  const match = Object.keys(allGalleryImages).find((path) =>
    path.includes(`/public/images/galeria/${folder}/`),
  );

  return match ? match.replace("/public", "") : null;
};

const fallbackImage =
  Object.keys(allGalleryImages)[0]?.replace("/public", "") ?? null;

const cards = [
  {
    title: "OPERACIONES CONJUNTAS",
    description:
      "Misiones a gran escala con roles coordinados entre infanteria, soporte y mando.",
    image: firstImageFrom("entrenamientos") ?? fallbackImage,
    alt: "Operators moving through mountainous terrain",
  },
  {
    title: "MISIONES DINAMICAS",
    description:
      "Objetivos que evolucionan en tiempo real segun las decisiones de cada escuadra.",
    image: firstImageFrom("misiones") ?? fallbackImage,
    alt: "Operators advancing in urban combat zone",
  },
  {
    title: "ENTORNOS VARIABLES",
    description:
      "Desde zonas urbanas hasta terreno abierto: cada operacion exige nuevas tacticas.",
    image: firstImageFrom("patrullas") ?? fallbackImage,
    alt: "Operators patrolling through a forest road",
  },
];
---

<section class="operations" id="operations">
  <div class="operations-left hud-border">
    <p class="operations-kicker">OPERACIONES</p>
    <h2>
      PLANIFICA.<br />
      EJECUTA.<br />
      CUMPLE.
    </h2>
    <p class="operations-copy">
      En Comando 99 realizamos operaciones MILSIM con disciplina, cadena de
      mando y trabajo en equipo en distintos escenarios.
    </p>
    <a class="operations-link" href="/galeria">VER ULTIMAS OPERACIONES</a>
  </div>

  <div class="operations-cards">
    {
      cards.map((card, index) => (
        <article class="operations-card hud-border">
          <div class="operations-image-wrap">
            {card.image ? (
              <Image
                src={card.image}
                alt={card.alt}
                width={1200}
                height={760}
                loading={index === 0 ? "eager" : "lazy"}
                decoding="async"
                fetchpriority={index === 0 ? "high" : "low"}
              />
            ) : (
              <div class="operations-image-fallback" aria-hidden="true" />
            )}
          </div>
          <div class="operations-content">
            <h3>{card.title}</h3>
            <p>{card.description}</p>
          </div>
        </article>
      ))
    }
  </div>

  <div class="operations-cta hud-border" aria-label="Llamado a la accion">
    <div class="operations-cta-copy">
      <p class="operations-cta-title">LISTO PARA UNIRTE A LA MISION?</p>
      <p class="operations-cta-text">
        Sumate a Comando 99 y participa en operaciones MILSIM con disciplina,
        cadena de mando y trabajo en equipo.
      </p>
    </div>
    <div class="operations-cta-actions">
      <a class="operations-cta-btn operations-cta-btn-ghost" href="/roles"
        >CONOCE LOS ROLES</a
      >
      <a class="operations-cta-btn operations-cta-btn-primary" href="/roles"
        >POSTULATE</a
      >
    </div>
  </div>
</section>

<style>
  .operations {
    display: grid;
    grid-template-columns: minmax(130px, 0.55fr) 2.05fr;
    gap: 1rem;
    margin-inline: 0;
    padding: 1.2rem;
    border-block: 1px solid rgba(201, 24, 16, 0.36);
    background: linear-gradient(180deg, #121212 0%, #0c0c0c 100%);
  }

  .operations-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.65rem;
    min-height: 100%;
    padding: 1.2rem 1.5rem;
    width: 20vw;
    background:
      linear-gradient(180deg, rgba(201, 24, 16, 0.12), rgba(201, 24, 16, 0)),
      rgba(0, 0, 0, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .operations-kicker {
    margin: 0;
    color: rgba(255, 255, 255, 0.78);
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    text-transform: uppercase;
    font-weight: 600;
  }

  .operations-left h2 {
    margin: 0;
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    line-height: 0.84;
    letter-spacing: 0.03em;
    border-bottom: 6px double rgb(129, 3, 3);
    width: fit-content;
  }

  .operations-copy {
    margin: 0;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.95rem;
    line-height: 1.45;
    max-width: 28ch;
  }

  .operations-link {
    margin-top: 0.75rem;
    width: fit-content;
    border: 1px solid rgba(255, 255, 255, 0.32);
    color: #f5f5f5;
    text-decoration: none;
    font-size: 0.75rem;
    letter-spacing: 0.11em;
    font-weight: 600;
    padding: 0.62rem 0.85rem;
    transition:
      background-color 0.25s ease,
      border-color 0.25s ease,
      transform 0.2s ease;
  }

  .operations-link:hover {
    background: rgba(201, 24, 16, 0.3);
    border-color: rgba(255, 255, 255, 0.56);
    transform: translateY(-1px);
  }

  .operations-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .operations-cta {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: space-around;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    margin-top: 0.2rem;
    padding: 1.7rem 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background:
      radial-gradient(
        circle at 94% 50%,
        rgba(255, 255, 255, 0.151),
        transparent 34%
      ),
      linear-gradient(90deg, rgba(29, 29, 29, 0.95), rgba(12, 12, 12, 0.92));
  }

  .operations-cta::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.2;
    background-image: url("/images/topographic.png");
    background-repeat: repeat-x;
    background-size: auto 180%;
    background-position: center;
    mix-blend-mode: screen;
    filter: contrast(1.05) brightness(0.9);
  }

  .operations-cta > * {
    position: relative;
    z-index: 1;
  }

  .operations-cta-copy {
    min-width: 0;
  }

  .operations-cta-title {
    margin: 0;
    font-family: "Stick No Bills";
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: clamp(1.05rem, 2vw, 1.6rem);
    line-height: 1;
    color: rgba(255, 255, 255, 0.95);
  }

  .operations-cta-text {
    margin: 0.35rem 0 0;
    font-size: 1.2rem;
    max-width: 70ch;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.2;
  }

  .operations-cta-actions {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
  }

  .operations-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 150px;
    padding: 0.72rem 1rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 1rem;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .operations-cta-btn:hover {
    transform: translateY(-1px);
  }

  .operations-cta-btn-ghost {
    border: 1px solid rgba(255, 255, 255, 0.34);
    color: rgba(255, 255, 255, 0.88);
    background: rgba(0, 0, 0, 0.42);
  }

  .operations-cta-btn-ghost:hover {
    border-color: rgba(255, 255, 255, 0.58);
    background: rgba(255, 255, 255, 0.08);
  }

  .operations-cta-btn-primary {
    border: 1px solid rgba(201, 24, 16, 0.95);
    color: #fff;
    background: linear-gradient(90deg, #990f0a, #c91810);
  }

  .operations-cta-btn-primary:hover {
    border-color: rgba(255, 255, 255, 0.45);
    background: linear-gradient(90deg, #ad120c, #d01f17);
  }

  .operations-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(9, 9, 9, 0.86);
    min-height: 100%;
  }

  .operations-image-wrap {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    aspect-ratio: 16 / 11;
    background: #111;
  }

  .operations-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.2);
    transition:
      transform 0.35s ease,
      filter 0.35s ease;
  }

  .operations-card:hover .operations-image-wrap img {
    transform: scale(1.04);
    filter: saturate(1.08);
  }

  .operations-image-fallback {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(circle at 20% 25%, #383838, #171717 48%),
      linear-gradient(120deg, #0f0f0f, #1a1a1a);
  }

  .operations-content {
    padding: 0.85rem 0.9rem 0.95rem;
  }

  .operations-content h3 {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1;
    font-family: "Stick No Bills";
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-align: center;
    border-bottom: 1px solid var(--bg-secondary);
  }

  .operations-content p {
    margin: 0.52rem 0 0;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.92rem;
    line-height: 1.32;
  }

  @media (max-width: 1100px) {
    .operations {
      grid-template-columns: 1fr;
    }

    .operations-left {
      width: 100%;
    }
    .operations-copy {
      max-width: none;
      font-size: 2rem;
    }

    .operations-kicker,
    .operations-left h2,
    .operations-link {
      text-align: center;
      font-size: 1em;
      width: 100%;
    }

    .operations-left h2 {
      /* font-size: clamp(2rem, 6vw, 2.9rem); */
      font-size: 6vw;

      br {
        display: none;
      }
    }
    .operations-link {
      width: 100%;
    }

    .operations-cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      p {
        font-size: 1em;
        padding-inline: 1rem;
      }
    }
    .operations-card:last-child {
      grid-column: span 2;
      height: 600px;
    }

    .operations-card h3 {
      font-size: 2em;
      padding-block: 1rem;
      background: #52040486;
    }
    .operations-card p {
      font-size: 2em;
      padding-bottom: 1rem;
    }
    .operations-card:last-child .operations-image-wrap {
      height: 50%;
    }

    .operations-cta {
      flex-direction: column;
      align-items: stretch;
      text-align: center;
    }

    .operations-cta-actions {
      justify-content: center;
    }

    .operations-cta-btn {
      min-width: 190px;
      font-size: 0.78rem;
    }
  }

  @media (max-width: 700px) {
    .operations {
      padding: 0.9rem;
      gap: 0.9rem;
    }

    .operations-cards {
      grid-template-columns: 1fr;
    }

    .operations-content h3 {
      font-size: 1rem;
    }

    .operations-copy {
      max-width: none;
    }

    .operations-cta {
      padding: 0.85rem;
      gap: 0.85rem;
    }

    .operations-cta-title {
      font-size: 1rem;
      line-height: 1.1;
    }

    .operations-cta-text {
      font-size: 0.84rem;
    }

    .operations-cta-actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .operations-cta-btn {
      width: 100%;
      min-width: 0;
    }
  }
</style>
