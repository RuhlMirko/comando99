---
import { Image } from "astro:assets";

const allGalleryImages = import.meta.glob("/public/images/galeria/**/*.*", {
  eager: true,
});

const firstImageFrom = (folder: string) => {
  const match = Object.keys(allGalleryImages).find((path) =>
    path.includes(`/public/images/galeria/${folder}/`),
  );

  return match ? match.replace("/public", "") : null;
};

const fallbackImage =
  Object.keys(allGalleryImages)[0]?.replace("/public", "") ?? null;

const cards = [
  {
    title: "JOINT OPERATIONS",
    description: "Large scale, combined arms. Coordination is key.",
    image: firstImageFrom("entrenamientos") ?? fallbackImage,
    alt: "Operators moving through mountainous terrain",
  },
  {
    title: "DYNAMIC MISSIONS",
    description: "Persistent objectives. Unpredictable outcomes.",
    image: firstImageFrom("misiones") ?? fallbackImage,
    alt: "Operators advancing in urban combat zone",
  },
  {
    title: "VARIED ENVIRONMENTS",
    description: "From Chernarus to Tanoa. No two ops are the same.",
    image: firstImageFrom("patrullas") ?? fallbackImage,
    alt: "Operators patrolling through a forest road",
  },
];
---

<section class="operations" id="operations">
  <div class="operations-left hud-border">
    <p class="operations-kicker">OPERATIONS</p>
    <h2>
      DEPLOY.<br />
      ADAPT.<br />
      OVERCOME.
    </h2>
    <p class="operations-copy">
      We run a variety of operations across different terrains and conflict
      types.
    </p>
    <a class="operations-link" href="/galeria">VIEW PAST OPS</a>
  </div>

  <div class="operations-cards">
    {
      cards.map((card) => (
        <article class="operations-card hud-border">
          <div class="operations-image-wrap">
            {card.image ? (
              <Image
                src={card.image}
                alt={card.alt}
                width={1200}
                height={760}
              />
            ) : (
              <div class="operations-image-fallback" aria-hidden="true" />
            )}
          </div>
          <div class="operations-content">
            <h3>{card.title}</h3>
            <p>{card.description}</p>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .operations {
    display: grid;
    grid-template-columns: minmax(230px, 0.95fr) 2.05fr;
    gap: 1rem;
    margin-inline: 0;
    padding: 1.2rem;
    border-block: 1px solid rgba(201, 24, 16, 0.36);
    background:
      radial-gradient(
        circle at 20% 8%,
        rgba(201, 24, 16, 0.14),
        rgba(0, 0, 0, 0) 38%
      ),
      linear-gradient(180deg, #050505 0%, #090909 100%);
  }

  .operations-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.65rem;
    min-height: 100%;
    padding: 1.2rem 1.05rem;
    background:
      linear-gradient(180deg, rgba(201, 24, 16, 0.12), rgba(201, 24, 16, 0)),
      rgba(0, 0, 0, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .operations-kicker {
    margin: 0;
    color: rgba(255, 255, 255, 0.78);
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    text-transform: uppercase;
    font-weight: 600;
  }

  .operations-left h2 {
    margin: 0;
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    line-height: 0.84;
    letter-spacing: 0.03em;
  }

  .operations-copy {
    margin: 0;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.95rem;
    line-height: 1.45;
    max-width: 28ch;
  }

  .operations-link {
    margin-top: 0.75rem;
    width: fit-content;
    border: 1px solid rgba(255, 255, 255, 0.32);
    color: #f5f5f5;
    text-decoration: none;
    font-size: 0.75rem;
    letter-spacing: 0.11em;
    font-weight: 600;
    padding: 0.62rem 0.85rem;
    transition:
      background-color 0.25s ease,
      border-color 0.25s ease,
      transform 0.2s ease;
  }

  .operations-link:hover {
    background: rgba(201, 24, 16, 0.3);
    border-color: rgba(255, 255, 255, 0.56);
    transform: translateY(-1px);
  }

  .operations-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .operations-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(9, 9, 9, 0.86);
    min-height: 100%;
  }

  .operations-image-wrap {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    aspect-ratio: 16 / 11;
    background: #111;
  }

  .operations-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.2);
    transition:
      transform 0.35s ease,
      filter 0.35s ease;
  }

  .operations-card:hover .operations-image-wrap img {
    transform: scale(1.04);
    filter: saturate(1.08);
  }

  .operations-image-fallback {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(circle at 20% 25%, #383838, #171717 48%),
      linear-gradient(120deg, #0f0f0f, #1a1a1a);
  }

  .operations-content {
    padding: 0.85rem 0.9rem 0.95rem;
  }

  .operations-content h3 {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .operations-content p {
    margin: 0.52rem 0 0;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.92rem;
    line-height: 1.32;
  }

  @media (max-width: 1100px) {
    .operations {
      grid-template-columns: 1fr;
    }

    .operations-left h2 {
      font-size: clamp(2rem, 6vw, 2.9rem);
    }

    .operations-cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .operations {
      padding: 0.9rem;
      gap: 0.9rem;
    }

    .operations-cards {
      grid-template-columns: 1fr;
    }

    .operations-content h3 {
      font-size: 1rem;
    }

    .operations-copy {
      max-width: none;
    }
  }
</style>
