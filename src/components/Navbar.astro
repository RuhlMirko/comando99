---
interface Props {
  navLinks: Record<string, string>;
  isNotFrontPage?: boolean;
}
const { navLinks, isNotFrontPage = false } = Astro.props;
const entries = Object.entries(navLinks);
---

<header>
  <nav>
    {
      isNotFrontPage && (
        <a href="/" class="go-home">
          <span>←</span>Volver al Inicio
        </a>
      )
    }
    <ul class="nav-links">
      {
        entries.map((item) => (
          <li>
            <a href={`#${item[0]}`}>{item[1]}</a>
          </li>
        ))
      }
    </ul>

    <div class="nav-menu">
      <button aria-label="Toggle navigation menu">
        <svg
          height="58"
          width="58"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
      <div class="nav-menu-modal">
        <ul>
          {
            entries.map((item) => (
              <li>
                <a href={`#${item[0]}`}>{item[1]}</a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </nav>
</header>
<style>
  * {
    box-sizing: border-box;
    padding: 0;
    margin: 0;
  }
  header {
    width: 100%;
    position: fixed;
    top: 0;
    z-index: 40;
    backdrop-filter: blur(25px);
  }
  .nav-links {
    padding-top: 1.4em;
    background: rgba(44, 20, 16, 0.719);
    display: flex;
    justify-content: center;
    list-style-type: none;
    padding-bottom: 1.2em;
    border-bottom: 1px solid rgba(255, 0, 0, 0.349);
    transform-origin: top;
  }
  nav {
    animation: reveal-nav-links 0.5s ease-in both;
  }
  .nav-links li a {
    color: inherit;
    text-decoration: none;
    font-weight: 600;
    letter-spacing: 1px;
    padding: 1em;
    transition: 0.2s;
    font-size: 1.2rem;
  }
  .nav-links li a:hover {
    background: rgba(255, 0, 0, 0.349);
  }
  .nav-menu {
    display: none;
  }

  .go-home {
    position: fixed;
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.404);
    background: #121212;
    text-decoration: none;
    padding: 6px 1em;
    display: block;
    width: fit-content;
    top: 1rem;
    left: 2rem;
    z-index: 40;
    transition: 0.2s;

    span {
      font-size: 1.2rem;
      line-height: 1;
      padding-right: 0.5rem;
    }

    &:hover {
      background: #3b0d0d;
      border-color: rgba(255, 255, 255, 0.466);
    }
  }

  @keyframes reveal-nav-links {
    from {
      opacity: 0.5;
      transform: translateY(-100%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-links {
      animation: none;
    }
  }

  @media (max-width: 590px) {
    header {
      backdrop-filter: none;
    }
    .nav-links {
      display: none;
    }
    .nav-menu {
      display: block;
      float: right;
    }
    .nav-menu button {
      display: block;
      height: 70px;
      width: 70px;
      background-color: #270606;
      color: rgba(255, 0, 0, 0.699);
      border: 2px solid rgba(153, 7, 7, 0.795);
      margin: 20px;
      transition: 0.2s;

      &:focus {
        background-color: rgb(177, 6, 6);
        color: black;
      }
    }
    .nav-menu-modal {
      position: fixed;
      top: 0;
      right: 0;
      height: 100vh;
      display: none;
      background: #270606d2;
      z-index: -1;

      ul {
        margin-top: 120px;
        display: flex;
        gap: 8vw;
        flex-direction: column;
        justify-content: center;
        align-items: end;
        list-style-type: none;
        padding-inline: 14px;

        li a {
          color: white;
          font-size: 2.3rem;
        }
      }
    }
    .active-modal {
      display: block;
    }
  }
</style>
<script>
  const navMenuBtn = document.querySelector(".nav-menu button");
  const navModal = document.querySelector(".nav-menu-modal");

  const navAnchors = document.querySelectorAll(
    '.nav-links a[href^="#"], .nav-menu-modal a[href^="#"]',
  );

  navMenuBtn?.addEventListener("click", function () {
    navModal?.classList.toggle("active-modal");
  });
  navModal?.addEventListener("click", function (e) {
    if ((e.target as HTMLElement).tagName === "A") {
      navModal?.classList.remove("active-modal");
    }
  });
</script>
