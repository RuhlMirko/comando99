---
interface Props {
  navLinks: Record<string, string>;
  isNotFrontPage?: boolean;
}

const { navLinks, isNotFrontPage = false } = Astro.props;
const entries = Object.entries(navLinks);
---

<header>
  <nav>
    {
      isNotFrontPage && (
        <a href="/" class="go-home">
          <span>←</span>Volver al Inicio
        </a>
      )
    }

    <div class="nav-shell">
      <a href="#hero" class="brand" aria-label="Comando 99 home">
        <img
          src="/images/logo.png"
          alt="Comando 99"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </a>

      <ul class="nav-links">
        {
          entries.map(([key, label]) => (
            <li>
              <a href={`#${key}`}>{label}</a>
            </li>
          ))
        }
      </ul>

      <a class="apply-now" href="https://discord.com/invite/UJUp2cWtwp"
        >Ingrese Ahora</a
      >

      <div class="nav-menu">
        <button aria-label="Toggle navigation menu" aria-expanded="false">
          <svg
            height="58"
            width="58"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>

        <div class="nav-menu-modal">
          <ul>
            {
              entries.map(([key, label]) => (
                <li>
                  <a href={`#${key}`}>{label}</a>
                </li>
              ))
            }
            <li>
              <a
                class="mobile-apply"
                href="https://discord.com/invite/UJUp2cWtwp">Ingrese Ahora</a
              >
            </li>
          </ul>
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  * {
    box-sizing: border-box;
  }

  header {
    position: fixed;
    top: 0;
    z-index: 5;
    width: 100%;
    background: linear-gradient(to bottom, black 30%, transparent 100%);
  }

  nav {
    position: relative;
    min-height: 5.5rem;
    padding: 1.65rem 1rem 0;
    background: transparent;
    animation: reveal-nav-links 0.5s ease-out;
  }

  .nav-shell {
    width: min(1440px, 100%);
    margin-inline: auto;
    display: flex;
    justify-content: space-around;
    align-items: center;
    gap: 1.25rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    text-decoration: none;
  }

  .brand img {
    width: 5.8rem;
    height: 5.8rem;
    object-fit: contain;
    filter: drop-shadow(0 0.75rem 1.25rem rgba(0, 0, 0, 0.5));
  }

  .nav-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-links li a {
    display: inline-flex;
    align-items: center;
    min-height: 2.9rem;
    padding: 0 1.25rem;
    color: rgba(255, 255, 255, 0.84);
    text-decoration: none;
    font-family: "Rajdhani", sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    text-transform: uppercase;
    border-bottom: 1px solid transparent;
    transition:
      color 0.2s ease,
      text-shadow 0.2s ease,
      background 0.5s ease-out,
      border-color 0.2s ease;
  }

  .nav-links li a:hover {
    color: #ffffff;
    text-shadow: 0 0 0.75rem rgba(201, 24, 16, 0.45);
    background: rgba(153, 9, 9, 0.527);
    border-color: red;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.88);
    text-decoration: none;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .icon-link svg {
    width: 1rem;
    height: 1rem;
  }

  .icon-link:hover {
    transform: translateY(-1px);
    background: rgba(201, 24, 16, 0.22);
    color: #ffffff;
  }

  .apply-now {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.7rem 1.1rem;
    border-radius: 0.08rem;
    background: linear-gradient(135deg, #b90f08, #dd2216);
    box-shadow: 0 0 1.1rem rgba(180, 16, 8, 0.28);
    color: #fff;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-family: "Rajdhani", sans-serif;
    font-size: 0.92rem;
    font-weight: 800;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease;
  }

  .apply-now:hover {
    transform: translateY(-1px);
    background: linear-gradient(135deg, #d31911, #f43627);
  }

  .nav-menu {
    display: none;
  }

  .go-home {
    position: absolute;
    top: 5dvh;
    left: 2dvw;
    z-index: 85;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 0.15rem;
    background: rgba(18, 18, 18, 0.9);
    color: white;
    text-decoration: none;
    font-style: italic;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease;
  }

  .go-home span {
    font-size: 1.2rem;
    line-height: 1;
  }

  .go-home:hover {
    background: rgba(59, 13, 13, 0.95);
    border-color: rgba(255, 255, 255, 0.24);
  }

  @keyframes reveal-nav-links {
    from {
      opacity: 0.5;
      transform: translateY(-100%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    nav {
      animation: none;
    }
  }

  @media (max-width: 710px) {
    header {
      backdrop-filter: none;
    }

    .nav-shell {
      grid-template-columns: auto auto;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .brand img {
      width: 4.7rem;
      aspect-ratio: 1;
      filter: brightness(1.5);
    }

    .nav-links,
    .nav-actions {
      display: none;
    }

    .nav-menu {
      display: block;
      justify-self: end;
    }

    .nav-menu button {
      display: block;
      height: 3.25rem;
      aspect-ratio: 1;
      padding: 6px;
      margin: 0;
      border: 1px solid rgba(153, 7, 7, 0.9);
      border-radius: 0.35rem;
      background: rgba(39, 6, 6, 0.92);
      color: rgba(255, 80, 80, 0.9);
      transition: 0.2s;
    }

    .nav-menu button:focus {
      background-color: rgb(177, 6, 6);
      color: black;
    }

    .nav-menu-modal {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100vh;
      display: none;
      background: rgba(0, 0, 0, 0.82);
      z-index: 90;
      backdrop-filter: blur(18px);
    }

    .nav-menu-modal ul {
      margin-top: 110px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      justify-content: flex-start;
      align-items: stretch;
      height: calc(100vh - 110px);
      padding-inline: 14px;
      list-style: none;
      font-family: "Stick No Bills";
      letter-spacing: 4px;
    }

    .nav-menu-modal li a {
      display: block;
      width: 80%;
      margin: 0 auto;
      padding: 15px 0;
      border: 1px solid rgba(153, 7, 7, 0.75);
      border-radius: 5px;
      background-color: rgba(39, 6, 6, 0.94);
      color: hsl(0, 100%, 60%);
      text-align: center;
      text-decoration: none;
      font-size: 2.1rem;
      font-weight: bold;
    }

    .nav-menu-modal li .mobile-apply {
      border-color: transparent;
      background: linear-gradient(135deg, #b90f08, #dd2216);
      color: #fff;
    }

    .active-modal {
      display: block;
    }
  }
</style>

<script>
  const navMenuButton =
    document.querySelector<HTMLButtonElement>(".nav-menu button");
  const navModal = document.querySelector<HTMLDivElement>(".nav-menu-modal");
  const navAnchors = document.querySelectorAll<HTMLAnchorElement>(
    '.nav-links a[href^="#"], .nav-menu-modal a[href^="#"]',
  );

  navMenuButton?.addEventListener("click", () => {
    const isOpen = navModal?.classList.toggle("active-modal") ?? false;
    navMenuButton.setAttribute("aria-expanded", String(isOpen));
  });

  navModal?.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).tagName === "A") {
      navModal.classList.remove("active-modal");
      navMenuButton?.setAttribute("aria-expanded", "false");
    }
  });

  navAnchors.forEach((anchor) => {
    anchor.addEventListener("click", () => {
      navModal?.classList.remove("active-modal");
      navMenuButton?.setAttribute("aria-expanded", "false");
    });
  });
</script>
